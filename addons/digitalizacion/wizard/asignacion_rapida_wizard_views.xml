<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_digitalizacion_asignacion_rapida_wizard_form" model="ir.ui.view">
        <field name="name">digitalizacion.asignacion_rapida.wizard.form</field>
        <field name="model">digitalizacion.asignacion_rapida_wizard</field>
        <field name="arch" type="xml">
            <form string="Asignación Rápida al Proyecto">
                <sheet>
                    <group>
                        <div class="alert alert-info" role="alert" colspan="2">
                            Seleccione el Proyecto y el Contacto a vincular. Si este contacto fue asignado previamente y dado de baja, se reactivará su perfil bajo este proyecto.
                        </div>
                    </group>
                    <group>
                        <field name="proyecto_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="partner_id" options="{'no_open': True}"/>
                        <field name="fecha_ingreso"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_asignar_miembro" string="Asignar al Proyecto" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_digitalizacion_asignacion_rapida_wizard" model="ir.actions.act_window">
        <field name="name">Asignación Rápida de Personal</field>
        <field name="res_model">digitalizacion.asignacion_rapida_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Agregar el botón de Acción en el Menú Operaciones debajo de Miembros del equipo -->
    <menuitem id="menu_asignacion_rapida"
          name="Asignación Rápida"
          parent="digitalizacion.menu_operaciones_root"
          action="action_digitalizacion_asignacion_rapida_wizard"
          sequence="30"/>
</odoo>
