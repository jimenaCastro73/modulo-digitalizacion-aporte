<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA FORM DEL WIZARD: CAMBIO DE ETAPA -->
    <record id="view_digitalizacion_cambio_etapa_wizard_form" model="ir.ui.view">
        <field name="name">digitalizacion.cambio_etapa.wizard.form</field>
        <field name="model">digitalizacion.cambio_etapa.wizard</field>
        <field name="arch" type="xml">
            <form string="Cambiar Etapa">
                <sheet>
                    <group>
                        <div class="alert alert-info text-center" role="alert">
                            Seleccione la nueva etapa a la que desea mover los registros seleccionados.
                        </div>
                    </group>
                    <group>
                        <field name="etapa_destino_id" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_cambiar_etapa" string="Aplicar Cambio" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ACCION DEL WIZARD -->
    <record id="action_digitalizacion_cambio_etapa_wizard" model="ir.actions.act_window">
        <field name="name">Cambiar Etapa</field>
        <field name="res_model">digitalizacion.cambio_etapa.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="digitalizacion.model_digitalizacion_registro"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
