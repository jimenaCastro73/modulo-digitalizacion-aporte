<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_digitalizacion" model="ir.module.category">
        <field name="name">Módulo de Digitalización</field>
        <field name="description">Roles del módulo de digitalización de documentos (OTEC GLOBAL).</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_digitalizacion_admin" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_category_digitalizacion" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
        <field name="comment">Acceso completo al backoffice: proyectos, asignaciones, registros, catálogos y dashboard de producción.</field>
    </record>

    <record id="group_digitalizacion_lider" model="res.groups">
        <field name="name">Líder de equipo</field>
        <field name="category_id" ref="module_category_digitalizacion" />
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]" />
        <field name="comment">Acceso solo al portal web. Registra la producción diaria de su equipo. No puede gestionar miembros ni acceder al backoffice.</field>
    </record>
</odoo>
