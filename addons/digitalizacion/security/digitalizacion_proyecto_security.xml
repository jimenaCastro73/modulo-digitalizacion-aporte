<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            El líder solo ve proyectos donde tiene una asignación activa.
            Se usa subquery explícita para evitar el problema del AND implícito
            en campos One2many: sin ella, Odoo evalúa cada condición por separado
            sobre el conjunto de asignaciones, lo que puede devolver resultados
            incorrectos si un proyecto tiene asignaciones de distintos líderes.
        -->
        <record id="rule_lider_solo_sus_proyectos" model="ir.rule">
            <field name="name">Lider ve sus proyectos activos</field>
            <field name="model_id" ref="model_digitalizacion_proyecto" />
            <field name="groups" eval="[(4, ref('group_digitalizacion_lider'))]" />
            <field name="perm_read" eval="True" />
            <field name="perm_write" eval="False" />
            <field name="perm_create" eval="False" />
            <field name="perm_unlink" eval="False" />
            <field name="domain_force">[('asignacion_ids.lider_id', '=', user.id)]</field>
        </record>
    </data>
</odoo>
