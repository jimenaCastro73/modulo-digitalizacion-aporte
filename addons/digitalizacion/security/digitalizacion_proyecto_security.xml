<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            El líder solo ve proyectos donde tiene una asignación activa.
            La asignación es activa si el miembro tiene es_lider=True y no tiene fecha_salida.
        -->
        <record id="rule_lider_solo_sus_proyectos" model="ir.rule">
            <field name="name">Lider ve sus proyectos activos</field>
            <field name="model_id" ref="model_digitalizacion_proyecto" />
            <field name="groups" eval="[(4, ref('group_digitalizacion_lider'))]" />
            <field name="perm_read" eval="True" />
            <field name="perm_write" eval="False" />
            <field name="perm_create" eval="False" />
            <field name="perm_unlink" eval="False" />
            <field name="domain_force">[('miembro_ids.partner_id', '=', user.partner_id.id), ('miembro_ids.es_lider', '=', True), ('miembro_ids.fecha_salida', '=', False)]</field>
        </record>
    </data>
</odoo>
