<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Breadcrumbs -->
    <template id="digitalizacion_portal_breadcrumbs" name="Portal layout : digitalizacion menu entries" inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'digitalizacion_dashboard'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_formulario'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_formulario'" class="breadcrumb-item active">Registro Diario</li>
            <li t-if="page_name == 'digitalizacion_proyecto'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_proyecto'" class="breadcrumb-item active">Proyecto</li>
            <li t-if="page_name == 'digitalizacion_miembros'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_miembros'" class="breadcrumb-item active">Equipo</li>
        </xpath>
    </template>
    <!-- Enlace en navbar — solo visible para líderes -->
    <template id="digitalizacion_website_menu" inherit_id="website.navbar_nav">
        <xpath expr="//ul[@id='top_menu']" position="inside">
            <t t-if="request.env.user.has_group('digitalizacion.digitalizacion_group_lider')">
                <li class="nav-item">
                    <a href="/digitalizacion/v1/dashboard" class="nav-link">
                        <i class="fa fa-th-large me-1" />
                        Digitalizacion
                    </a>
                </li>
            </t>
        </xpath>
    </template>
    <!-- Portal home entry -->
    <template id="digitalizacion_portal_home_entry" name="Displays Digitalizacion in Portal Home" inherit_id="portal.portal_my_home" customize_show="True" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Registro de Producción</t>
                <t t-set="url" t-value="'/digitalizacion/v1/dashboard'" />
                <t t-set="placeholder_count" t-value="'digitalizacion_count'" />
            </t>
        </xpath>
    </template>
    <!-- ================================================================
         DASHBOARD DEL LÍDER — /digitalizacion
         ================================================================ -->
    <template id="digitalizacion_portal_dashboard" name="Dashboard Líder">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <!-- Sin proyectos asignados -->
            <div t-if="not asignaciones" class="o_digitalizacion_empty mt-5">
                <i class="fa fa-folder-open-o" />
                <p class="fw-bold">Sin proyectos asignados</p>
                <p class="small">Contacta al administrador para que te asigne a un proyecto.</p>
            </div>
            <div t-if="asignaciones" class="o_digitalizacion_page pb-5">
                <!-- ── Topbar sticky ──────────────────────────── -->
                <div class="o_digitalizacion_topbar">
                    <div class="container-fluid px-3 px-md-4">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 o_digitalizacion_topbar-actions">
                            <div class="d-flex align-items-center gap-3">
                                <!-- Selector de proyecto -->
                                <form method="GET" action="/digitalizacion/v1/dashboard" class="d-flex align-items-center gap-2">
                                    <i class="fa fa-folder-open text-primary" />
                                    <select name="proyecto_id" class="o_digitalizacion_project-select" onchange="this.form.submit()">
                                        <t t-foreach="asignaciones" t-as="asig">
                                            <option t-att-value="asig.proyecto_id.id" t-att-selected="request.params.get('proyecto_id') == str(asig.proyecto_id.id)">
                                                <t t-esc="asig.proyecto_id.name" />
                                            </option>
                                        </t>
                                    </select>
                                </form>
                                <span class="o_digitalizacion_period text-muted small d-none d-md-inline">
                                    <i class="fa fa-calendar-o me-1" />
                                    <t t-esc="periodo_actual" />
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <!-- Filtros período -->
                                <div class="o_digitalizacion_period-pills">
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=hoy" t-att-class="'active' if request.params.get('periodo') == 'hoy' else ''">Hoy</a>
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=semana" t-att-class="'active' if request.params.get('periodo') == 'semana' else ''">Semana</a>
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=mes" t-att-class="'active' if not request.params.get('periodo') or request.params.get('periodo') == 'mes' else ''">Mes</a>
                                </div>
                                <!-- Botón registrar -->
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{request.params.get('proyecto_id') or asignaciones[0].proyecto_id.id}/form" class="o_digitalizacion_btn o_digitalizacion_btn--primary">
                                    <i class="fa fa-plus" />
                                    Registrar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="container-fluid px-3 px-md-4 mt-4">
                    <t t-if="notifications">
                        <t t-foreach="notifications" t-as="noti">
                            <div t-attf-class="alert alert-#{noti['type']} alert-dismissible fade show" role="alert">
                                <t t-esc="noti['message']" />
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" />
                            </div>
                        </t>
                    </t>
                    <!-- ── KPIs ───────────────────────────────── -->
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="o_digitalizacion_kpi o_digitalizacion_kpi--escaneos">
                                <div class="o_digitalizacion_kpi__label">
                                    <i class="fa fa-barcode me-1" />
                                    Escaneos
                                </div>
                                <div class="o_digitalizacion_kpi__value">
                                    <t t-esc="kpis.get('escaneos', 0)" />
                                </div>
                                <div class="o_digitalizacion_kpi__sub">Hojas digitalizadas</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="o_digitalizacion_kpi o_digitalizacion_kpi--folios">
                                <div class="o_digitalizacion_kpi__label">
                                    <i class="fa fa-file-o me-1" />
                                    Folios físicos
                                </div>
                                <div class="o_digitalizacion_kpi__value">
                                    <t t-esc="kpis.get('folios_fisicos', 0)" />
                                </div>
                                <div class="o_digitalizacion_kpi__sub">Procesados</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="o_digitalizacion_kpi o_digitalizacion_kpi--indexados">
                                <div class="o_digitalizacion_kpi__label">
                                    <i class="fa fa-tags me-1" />
                                    Exp. indexados
                                </div>
                                <div class="o_digitalizacion_kpi__value">
                                    <t t-esc="kpis.get('exp_indexados', 0)" />
                                </div>
                                <div class="o_digitalizacion_kpi__sub">Expedientes</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="o_digitalizacion_kpi o_digitalizacion_kpi--registros">
                                <div class="o_digitalizacion_kpi__label">
                                    <i class="fa fa-send-o me-1" />
                                    Envíos
                                </div>
                                <div class="o_digitalizacion_kpi__value">
                                    <t t-esc="kpis.get('total_registros', 0)" />
                                </div>
                                <div class="o_digitalizacion_kpi__sub">Formularios enviados</div>
                            </div>
                        </div>
                    </div>
                    <!-- ── Contenido principal ────────────────── -->
                    <!-- ── Accesos rápidos ────────────────────── -->
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <div class="o_digitalizacion_card">
                                <div class="o_digitalizacion_card__body d-flex flex-wrap gap-2 align-items-center">
                                    <span class="text-muted small me-2">Accesos rápidos:</span>
                                    <t t-foreach="asignaciones" t-as="asig">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{asig.proyecto_id.id}" class="o_digitalizacion_btn o_digitalizacion_btn--outline" style="font-size:.8rem;">
                                            <i class="fa fa-folder-o" />
                                            <t t-esc="asig.proyecto_id.name" />
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <!-- Producción por etapa -->
                        <div class="col-12 col-lg-4">
                            <div class="o_digitalizacion_card h-100">
                                <div class="o_digitalizacion_card__header">
                                    <i class="fa fa-bar-chart" />
                                    Producción por etapa
                                </div>
                                <div class="o_digitalizacion_card__body">
                                    <t t-if="not resumen_etapas">
                                        <div class="o_digitalizacion_empty">
                                            <i class="fa fa-inbox" />
                                            <p class="small mb-0">Sin datos en este período</p>
                                        </div>
                                    </t>
                                    <t t-foreach="resumen_etapas" t-as="etapa">
                                        <div class="o_digitalizacion_etapa-bar">
                                            <div class="o_digitalizacion_etapa-bar__label">
                                                <span>
                                                    <t t-esc="etapa.get('nombre')" />
                                                </span>
                                                <span>
                                                    <t t-esc="etapa.get('cantidad')" />
                                                </span>
                                            </div>
                                            <div class="o_digitalizacion_progress">
                                                <div t-attf-style="width: #{etapa.get('porcentaje')}%" class="o_digitalizacion_progress__fill" />
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <!-- Registros recientes -->
                        <div class="col-12 col-lg-8">
                            <div class="o_digitalizacion_card h-100">
                                <div class="o_digitalizacion_card__header">
                                    <i class="fa fa-history" />
                                    Envíos recientes
                                    <span class="ms-auto">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{request.params.get('proyecto_id') or asignaciones[0].proyecto_id.id}/form" class="o_digitalizacion_btn o_digitalizacion_btn--outline" style="font-size:.78rem; padding:.25rem .7rem;">
                                            <i class="fa fa-plus" />
                                            Nuevo registro
                                        </a>
                                    </span>
                                </div>
                                <t t-if="not ultimos_registros">
                                    <div class="o_digitalizacion_empty">
                                        <i class="fa fa-inbox" />
                                        <p class="small mb-0">No hay registros en este período</p>
                                    </div>
                                </t>
                                <div t-if="ultimos_registros" class="table-responsive">
                                    <table class="o_digitalizacion_table">
                                        <thead>
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Miembro</th>
                                                <th>Etapa</th>
                                                <th class="text-end">Producción</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="ultimos_registros" t-as="reg">
                                                <tr>
                                                    <td class="text-muted">
                                                        <t t-esc="reg.fecha.strftime('%d/%m') if reg.fecha else ''" />
                                                    </td>
                                                    <td class="fw-500">
                                                        <t t-esc="reg.miembro_id.partner_id.name.split(' ')[0] if reg.miembro_id else '?'" />
                                                    </td>
                                                    <td>
                                                        <span class="o_digitalizacion_badge">
                                                            <t t-esc="reg.etapa_id.name" />
                                                        </span>
                                                    </td>
                                                    <td class="text-end fw-bold">
                                                        <t t-esc="reg.produccion_principal" />
                                                        <span class="text-muted fw-normal ms-1" style="font-size:.78rem;">
                                                            <t t-esc="reg.unidad_produccion" />
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /row -->
                    <!-- ── Accesos rápidos ────────────────────── -->
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <div class="o_digitalizacion_card">
                                <div class="o_digitalizacion_card__body d-flex flex-wrap gap-2 align-items-center">
                                    <span class="text-muted small me-2">Accesos rápidos:</span>
                                    <t t-foreach="asignaciones" t-as="asig">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{asig.proyecto_id.id}" class="o_digitalizacion_btn o_digitalizacion_btn--outline" style="font-size:.8rem;">
                                            <i class="fa fa-folder-o" />
                                            <t t-esc="asig.proyecto_id.name" />
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /container -->
            </div>
            <!-- /o_digitalizacion_page -->
        </t>
    </template>
</odoo>