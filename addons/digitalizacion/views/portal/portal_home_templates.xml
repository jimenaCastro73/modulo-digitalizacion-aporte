<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Breadcrumbs -->
    <template id="portal_my_home_menu_digitalizacion" name="Portal layout : digitalizacion menu entries" inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'digitalizacion_dashboard'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_formulario'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_formulario'" class="breadcrumb-item active">Registro Diario</li>
            <li t-if="page_name == 'digitalizacion_proyecto'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_proyecto'" class="breadcrumb-item active">Proyecto</li>
            <li t-if="page_name == 'digitalizacion_miembros'" class="breadcrumb-item">
                <a href="/digitalizacion/v1/dashboard">Producción</a>
            </li>
            <li t-if="page_name == 'digitalizacion_miembros'" class="breadcrumb-item active">Equipo</li>
        </xpath>
    </template>
    <!-- Enlace en navbar — solo visible para líderes -->
    <template id="website_menu_digitalizacion" inherit_id="website.navbar_nav">
        <xpath expr="//ul[@id='top_menu']" position="inside">
            <t t-if="request.env.user.has_group('digitalizacion.group_digitalizacion_lider')">
                <li class="nav-item">
                    <a href="/digitalizacion/v1/dashboard" class="nav-link">
                        <i class="fa fa-th-large me-1" />
                        Digitalizacion
                    </a>
                </li>
            </t>
        </xpath>
    </template>
    <!-- Portal home entry -->
    <template id="portal_my_home_digitalizacion" name="Displays Digitalizacion in Portal Home" inherit_id="portal.portal_my_home" customize_show="True" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Registro de Producción</t>
                <t t-set="url" t-value="'/digitalizacion/v1/dashboard'" />
                <t t-set="placeholder_count" t-value="'digitalizacion_count'" />
            </t>
        </xpath>
    </template>
    <!-- ================================================================
         DASHBOARD DEL LÍDER — /digitalizacion
         ================================================================ -->
    <template id="wf02_dashboard" name="Dashboard Líder">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <style>/* ── Paleta de colores del proyecto ──────────────── */
                :root {
                    --color-50:  #FCE8E8;
                    --color-100: #F8C0BF;
                    --color-200: #F39795;
                    --color-300: #EF6E6C;
                    --color-400: #EA4643;
                    --color-500: #DE1C19;
                    --color-600: #BC1815;
                    --color-700: #931210;
                    --color-800: #6A0D0C;
                    --color-900: #400807;
                    --color-950: #170303;
                    --color-white: #ffffff;

                    /* ── Variables semánticas ── */
                    --dg-primary:       var(--color-500);
                    --dg-primary-light: var(--color-50);
                    --dg-success:   #059669;
                    --dg-warning:   #d97706;
                    --dg-info:      #0284c7;
                    --dg-danger:    var(--color-500);
                    --dg-surface:   var(--color-white);
                    --dg-bg:        #f8fafc;
                    --dg-border:    var(--color-100);
                    --dg-text:      var(--color-950);
                    --dg-muted:     var(--color-700);
                    --dg-radius:    12px;
                    --dg-shadow:    0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
                    --dg-shadow-md: 0 4px 6px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
                }

                /* ── Layout base ─────────────────────────────────── */
                .dg-page { background: var(--dg-bg); min-height: 100vh; }

                /* ── Topbar de proyecto ──────────────────────────── */
                .dg-topbar {
                    background: var(--dg-surface);
                    border-bottom: 1px solid var(--dg-border);
                    padding: 1rem 0;
                    position: sticky;
                    top: 0;
                    z-index: 100;
                }
                .dg-topbar h4 { color: var(--dg-text); font-weight: 700; margin: 0; font-size: 1.1rem; }
                .dg-topbar .dg-period { color: var(--dg-muted); font-size: .82rem; }

                /* ── Selector de proyecto ────────────────────────── */
                .dg-project-select {
                    background: var(--dg-primary-light);
                    border: 1.5px solid var(--dg-primary);
                    border-radius: 8px;
                    color: var(--dg-primary);
                    font-weight: 600;
                    font-size: .85rem;
                    padding: .35rem .75rem;
                    cursor: pointer;
                    outline: none;
                }

                /* ── Filtros de período ──────────────────────────── */
                .dg-period-pills { display: flex; gap: .4rem; flex-wrap: wrap; }
                .dg-period-pills a {
                    padding: .3rem .8rem;
                    border-radius: 20px;
                    font-size: .8rem;
                    font-weight: 500;
                    text-decoration: none;
                    background: var(--dg-border);
                    color: var(--dg-muted);
                    transition: all .15s;
                }
                .dg-period-pills a.active,
                .dg-period-pills a:hover {
                    background: var(--dg-primary);
                    color: #fff;
                }

                /* ── KPI Cards ───────────────────────────────────── */
                .dg-kpi {
                    background: var(--dg-surface);
                    border-radius: var(--dg-radius);
                    box-shadow: var(--dg-shadow);
                    padding: 1.25rem 1.5rem;
                    border-left: 4px solid transparent;
                    transition: transform .15s, box-shadow .15s;
                }
                .dg-kpi:hover { transform: translateY(-2px); box-shadow: var(--dg-shadow-md); }
                .dg-kpi--escaneos  { border-color: var(--dg-primary); }
                .dg-kpi--folios    { border-color: var(--dg-info); }
                .dg-kpi--indexados { border-color: var(--dg-success); }
                .dg-kpi--registros { border-color: var(--dg-warning); }
                .dg-kpi__label { font-size: .72rem; font-weight: 700; text-transform: uppercase;
                                 letter-spacing: .05em; color: var(--dg-muted); margin-bottom: .25rem; }
                .dg-kpi__value { font-size: 2rem; font-weight: 800; color: var(--dg-text); line-height: 1; }
                .dg-kpi__sub   { font-size: .78rem; color: var(--dg-muted); margin-top: .2rem; }

                /* ── Cards genéricas ─────────────────────────────── */
                .dg-card {
                    background: var(--dg-surface);
                    border-radius: var(--dg-radius);
                    box-shadow: var(--dg-shadow);
                    overflow: hidden;
                }
                .dg-card__header {
                    padding: 1rem 1.25rem;
                    border-bottom: 1px solid var(--dg-border);
                    font-weight: 700;
                    font-size: .9rem;
                    color: var(--dg-text);
                    display: flex;
                    align-items: center;
                    gap: .5rem;
                }
                .dg-card__header i { color: var(--dg-primary); }
                .dg-card__body { padding: 1.25rem; }

                /* ── Barras de etapa ─────────────────────────────── */
                .dg-etapa-bar { margin-bottom: .9rem; }
                .dg-etapa-bar__label {
                    display: flex; justify-content: space-between;
                    font-size: .82rem; margin-bottom: .3rem;
                }
                .dg-etapa-bar__label span:first-child { color: var(--dg-text); font-weight: 500; }
                .dg-etapa-bar__label span:last-child  { color: var(--dg-primary); font-weight: 700; }
                .dg-progress {
                    height: 6px; border-radius: 99px;
                    background: var(--dg-border); overflow: hidden;
                }
                .dg-progress__fill {
                    height: 100%; border-radius: 99px;
                    background: linear-gradient(90deg, var(--color-500), var(--color-600));
                    transition: width .4s ease;
                }

                /* ── Tabla de registros recientes ────────────────── */
                .dg-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
                .dg-table th {
                    background: var(--dg-bg); color: var(--dg-muted);
                    font-size: .72rem; font-weight: 700; text-transform: uppercase;
                    letter-spacing: .04em; padding: .6rem 1rem;
                    border-bottom: 1px solid var(--dg-border); text-align: left;
                }
                .dg-table td { padding: .7rem 1rem; border-bottom: 1px solid var(--dg-border); color: var(--dg-text); }
                .dg-table tr:last-child td { border-bottom: none; }
                .dg-table tr:hover td { background: var(--dg-primary-light); }

                /* ── Badge de etapa ──────────────────────────────── */
                .dg-badge {
                    display: inline-block; padding: .2rem .6rem;
                    border-radius: 99px; font-size: .72rem; font-weight: 600;
                    background: var(--dg-primary-light); color: var(--dg-primary);
                }

                /* ── Botón primario ──────────────────────────────── */
                .dg-btn {
                    display: inline-flex; align-items: center; gap: .4rem;
                    padding: .55rem 1.1rem; border-radius: 8px; font-weight: 600;
                    font-size: .85rem; text-decoration: none; cursor: pointer;
                    border: none; transition: all .15s;
                }
                .dg-btn--primary {
                    background: var(--dg-primary); color: #fff;
                }
                .dg-btn--primary:hover { background: var(--color-700); color: var(--color-white); transform: translateY(-1px); }
                .dg-btn--outline {
                    background: transparent; color: var(--dg-primary);
                    border: 1.5px solid var(--dg-primary);
                }
                .dg-btn--outline:hover { background: var(--dg-primary-light); }

                /* ── Estado vacío ────────────────────────────────── */
                .dg-empty {
                    text-align: center; padding: 3rem 1rem; color: var(--dg-muted);
                }
                .dg-empty i { font-size: 2.5rem; margin-bottom: .75rem; display: block; opacity: .4; }

                /* ── Responsive ──────────────────────────────────── */
                @media (max-width: 768px) {
                    .dg-kpi__value { font-size: 1.5rem; }
                    .dg-topbar-actions { flex-direction: column; align-items: flex-start !important; gap: .75rem !important; }
                }</style>
            <!-- Sin proyectos asignados -->
            <div t-if="not asignaciones" class="dg-empty mt-5">
                <i class="fa fa-folder-open-o" />
                <p class="fw-bold">Sin proyectos asignados</p>
                <p class="small">Contacta al administrador para que te asigne a un proyecto.</p>
            </div>
            <div t-if="asignaciones" class="dg-page pb-5">
                <!-- ── Topbar sticky ──────────────────────────── -->
                <div class="dg-topbar">
                    <div class="container-fluid px-3 px-md-4">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 dg-topbar-actions">
                            <div class="d-flex align-items-center gap-3">
                                <!-- Selector de proyecto -->
                                <form method="GET" action="/digitalizacion/v1/dashboard" class="d-flex align-items-center gap-2">
                                    <i class="fa fa-folder-open text-primary" />
                                    <select name="proyecto_id" class="dg-project-select" onchange="this.form.submit()">
                                        <t t-foreach="asignaciones" t-as="asig">
                                            <option t-att-value="asig.proyecto_id.id" t-att-selected="request.params.get('proyecto_id') == str(asig.proyecto_id.id)">
                                                <t t-esc="asig.proyecto_id.name" />
                                            </option>
                                        </t>
                                    </select>
                                </form>
                                <span class="dg-period text-muted small d-none d-md-inline">
                                    <i class="fa fa-calendar-o me-1" />
                                    <t t-esc="periodo_actual" />
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <!-- Filtros período -->
                                <div class="dg-period-pills">
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=hoy" t-att-class="'active' if request.params.get('periodo') == 'hoy' else ''">Hoy</a>
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=semana" t-att-class="'active' if request.params.get('periodo') == 'semana' else ''">Semana</a>
                                    <a t-attf-href="/digitalizacion/v1/dashboard?proyecto_id=#{request.params.get('proyecto_id', '')}&amp;periodo=mes" t-att-class="'active' if not request.params.get('periodo') or request.params.get('periodo') == 'mes' else ''">Mes</a>
                                </div>
                                <!-- Botón registrar -->
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{request.params.get('proyecto_id') or asignaciones[0].proyecto_id.id}/form" class="dg-btn dg-btn--primary">
                                    <i class="fa fa-plus" />
                                    Registrar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="container-fluid px-3 px-md-4 mt-4">
                    <t t-if="notifications">
                        <t t-foreach="notifications" t-as="noti">
                            <div t-attf-class="alert alert-#{noti['type']} alert-dismissible fade show" role="alert">
                                <t t-esc="noti['message']" />
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" />
                            </div>
                        </t>
                    </t>
                    <!-- ── KPIs ───────────────────────────────── -->
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="dg-kpi dg-kpi--escaneos">
                                <div class="dg-kpi__label">
                                    <i class="fa fa-barcode me-1" />
                                    Escaneos
                                </div>
                                <div class="dg-kpi__value">
                                    <t t-esc="kpis.get('escaneos', 0)" />
                                </div>
                                <div class="dg-kpi__sub">Hojas digitalizadas</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="dg-kpi dg-kpi--folios">
                                <div class="dg-kpi__label">
                                    <i class="fa fa-file-o me-1" />
                                    Folios físicos
                                </div>
                                <div class="dg-kpi__value">
                                    <t t-esc="kpis.get('folios_fisicos', 0)" />
                                </div>
                                <div class="dg-kpi__sub">Procesados</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="dg-kpi dg-kpi--indexados">
                                <div class="dg-kpi__label">
                                    <i class="fa fa-tags me-1" />
                                    Exp. indexados
                                </div>
                                <div class="dg-kpi__value">
                                    <t t-esc="kpis.get('exp_indexados', 0)" />
                                </div>
                                <div class="dg-kpi__sub">Expedientes</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="dg-kpi dg-kpi--registros">
                                <div class="dg-kpi__label">
                                    <i class="fa fa-send-o me-1" />
                                    Envíos
                                </div>
                                <div class="dg-kpi__value">
                                    <t t-esc="kpis.get('total_registros', 0)" />
                                </div>
                                <div class="dg-kpi__sub">Formularios enviados</div>
                            </div>
                        </div>
                    </div>
                    <!-- ── Contenido principal ────────────────── -->
                    <!-- ── Accesos rápidos ────────────────────── -->
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <div class="dg-card">
                                <div class="dg-card__body d-flex flex-wrap gap-2 align-items-center">
                                    <span class="text-muted small me-2">Accesos rápidos:</span>
                                    <t t-foreach="asignaciones" t-as="asig">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{asig.proyecto_id.id}" class="dg-btn dg-btn--outline" style="font-size:.8rem;">
                                            <i class="fa fa-folder-o" />
                                            <t t-esc="asig.proyecto_id.name" />
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <!-- Producción por etapa -->
                        <div class="col-12 col-lg-4">
                            <div class="dg-card h-100">
                                <div class="dg-card__header">
                                    <i class="fa fa-bar-chart" />
                                    Producción por etapa
                                </div>
                                <div class="dg-card__body">
                                    <t t-if="not resumen_etapas">
                                        <div class="dg-empty">
                                            <i class="fa fa-inbox" />
                                            <p class="small mb-0">Sin datos en este período</p>
                                        </div>
                                    </t>
                                    <t t-foreach="resumen_etapas" t-as="etapa">
                                        <div class="dg-etapa-bar">
                                            <div class="dg-etapa-bar__label">
                                                <span>
                                                    <t t-esc="etapa.get('nombre')" />
                                                </span>
                                                <span>
                                                    <t t-esc="etapa.get('cantidad')" />
                                                </span>
                                            </div>
                                            <div class="dg-progress">
                                                <div t-attf-style="width: #{etapa.get('porcentaje')}%" class="dg-progress__fill" />
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <!-- Registros recientes -->
                        <div class="col-12 col-lg-8">
                            <div class="dg-card h-100">
                                <div class="dg-card__header">
                                    <i class="fa fa-history" />
                                    Envíos recientes
                                    <span class="ms-auto">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{request.params.get('proyecto_id') or asignaciones[0].proyecto_id.id}/form" class="dg-btn dg-btn--outline" style="font-size:.78rem; padding:.25rem .7rem;">
                                            <i class="fa fa-plus" />
                                            Nuevo registro
                                        </a>
                                    </span>
                                </div>
                                <t t-if="not ultimos_registros">
                                    <div class="dg-empty">
                                        <i class="fa fa-inbox" />
                                        <p class="small mb-0">No hay registros en este período</p>
                                    </div>
                                </t>
                                <div t-if="ultimos_registros" class="table-responsive">
                                    <table class="dg-table">
                                        <thead>
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Miembro</th>
                                                <th>Etapa</th>
                                                <th class="text-end">Producción</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="ultimos_registros" t-as="reg">
                                                <tr>
                                                    <td class="text-muted">
                                                        <t t-esc="reg.fecha.strftime('%d/%m') if reg.fecha else ''" />
                                                    </td>
                                                    <td class="fw-500">
                                                        <t t-esc="reg.miembro_id.partner_id.name.split(' ')[0] if reg.miembro_id else '?'" />
                                                    </td>
                                                    <td>
                                                        <span class="dg-badge">
                                                            <t t-esc="reg.etapa_id.name" />
                                                        </span>
                                                    </td>
                                                    <td class="text-end fw-bold">
                                                        <t t-esc="reg.produccion_principal" />
                                                        <span class="text-muted fw-normal ms-1" style="font-size:.78rem;">
                                                            <t t-esc="reg.unidad_produccion" />
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /row -->
                    <!-- ── Accesos rápidos ────────────────────── -->
                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <div class="dg-card">
                                <div class="dg-card__body d-flex flex-wrap gap-2 align-items-center">
                                    <span class="text-muted small me-2">Accesos rápidos:</span>
                                    <t t-foreach="asignaciones" t-as="asig">
                                        <a t-attf-href="/digitalizacion/v1/proyectos/#{asig.proyecto_id.id}" class="dg-btn dg-btn--outline" style="font-size:.8rem;">
                                            <i class="fa fa-folder-o" />
                                            <t t-esc="asig.proyecto_id.name" />
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /container -->
            </div>
            <!-- /dg-page -->
        </t>
    </template>
</odoo>