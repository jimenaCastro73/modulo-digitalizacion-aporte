<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="wf04_proyecto_detalle" name="Detalle del Proyecto">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <style>:root {
                    --color-50:  #FCE8E8;
                    --color-100: #F8C0BF;
                    --color-200: #F39795;
                    --color-300: #EF6E6C;
                    --color-400: #EA4643;
                    --color-500: #DE1C19;
                    --color-600: #BC1815;
                    --color-700: #931210;
                    --color-800: #6A0D0C;
                    --color-900: #400807;
                    --color-950: #170303;
                    --color-white: #ffffff;

                    --dg-primary:       var(--color-500);
                    --dg-primary-light: var(--color-50);
                    --dg-success:       #059669;
                    --dg-surface:       var(--color-white);
                    --dg-bg:            #f8fafc;
                    --dg-border:        var(--color-100);
                    --dg-text:          var(--color-950);
                    --dg-muted:         var(--color-700);
                    --dg-radius:        12px;
                    --dg-shadow:        0 1px 3px rgba(0,0,0,.08);
                }
                .dg-page { background: var(--dg-bg); min-height: 80vh; }

                /* ── Hero del proyecto ───────────────────────────── */
                .dg-project-hero {
                    background: linear-gradient(135deg, var(--color-600) 0%, var(--color-800) 100%);
                    color: #fff;
                    padding: 2.5rem 1.5rem;
                    border-radius: 0 0 var(--dg-radius) var(--dg-radius);
                    margin-bottom: 1.5rem;
                    position: relative;
                    overflow: hidden;
                }
                .dg-project-hero::before {
                    content: '';
                    position: absolute; top: -40px; right: -40px;
                    width: 180px; height: 180px;
                    border-radius: 50%;
                    background: rgba(255,255,255,.06);
                }
                .dg-project-hero::after {
                    content: '';
                    position: absolute; bottom: -60px; right: 60px;
                    width: 120px; height: 120px;
                    border-radius: 50%;
                    background: rgba(255,255,255,.04);
                }
                .dg-project-hero h2 {
                    font-size: 1.6rem; font-weight: 800;
                    margin: 0 0 .25rem; line-height: 1.2;
                }
                .dg-project-hero .dg-status {
                    display: inline-flex; align-items: center; gap: .35rem;
                    background: rgba(255,255,255,.2);
                    padding: .2rem .7rem; border-radius: 99px;
                    font-size: .78rem; font-weight: 600;
                }
                .dg-project-hero .dg-dates {
                    font-size: .82rem; opacity: .85; margin-top: .5rem;
                }

                /* ── Barra de progreso del hero ──────────────────── */
                .dg-hero-progress { margin-top: 1.25rem; }
                .dg-hero-progress__label {
                    display: flex; justify-content: space-between;
                    font-size: .8rem; margin-bottom: .4rem; opacity: .9;
                }
                .dg-hero-progress__bar {
                    height: 8px; border-radius: 99px;
                    background: rgba(255,255,255,.25);
                    overflow: hidden;
                }
                .dg-hero-progress__fill {
                    height: 100%; border-radius: 99px;
                    background: #fff;
                    transition: width .5s ease;
                }

                /* ── Cards de acciones ───────────────────────────── */
                .dg-action-card {
                    background: var(--dg-surface);
                    border: 1px solid var(--dg-border);
                    border-radius: var(--dg-radius);
                    padding: 1.5rem;
                    text-decoration: none;
                    color: var(--dg-text);
                    display: flex;
                    align-items: center;
                    gap: 1rem;
                    box-shadow: var(--dg-shadow);
                    transition: all .15s;
                }
                .dg-action-card:hover {
                    border-color: var(--dg-primary);
                    box-shadow: 0 4px 12px rgba(222,28,25,.15);
                    transform: translateY(-2px);
                    color: var(--dg-text);
                    text-decoration: none;
                }
                .dg-action-card__icon {
                    width: 48px; height: 48px; border-radius: 12px;
                    display: flex; align-items: center; justify-content: center;
                    font-size: 1.3rem; flex-shrink: 0;
                }
                .dg-action-card__icon--primary { background: var(--dg-primary-light); color: var(--dg-primary); }
                .dg-action-card__icon--green   { background: #d1fae5; color: var(--dg-success); }
                .dg-action-card__title { font-weight: 700; font-size: .95rem; }
                .dg-action-card__desc  { font-size: .8rem; color: var(--dg-muted); margin-top: .15rem; }
                .dg-action-card__arrow {
                    margin-left: auto; color: var(--dg-muted); font-size: .9rem;
                    transition: transform .15s;
                }
                .dg-action-card:hover .dg-action-card__arrow { transform: translateX(3px); }

                /* ── Info del proyecto ───────────────────────────── */
                .dg-info-card {
                    background: var(--dg-surface);
                    border: 1px solid var(--dg-border);
                    border-radius: var(--dg-radius);
                    padding: 1.25rem 1.5rem;
                    box-shadow: var(--dg-shadow);
                }
                .dg-info-card__title {
                    font-size: .72rem; font-weight: 700; text-transform: uppercase;
                    letter-spacing: .05em; color: var(--dg-muted); margin-bottom: .9rem;
                    display: flex; align-items: center; gap: .4rem;
                }
                .dg-info-row {
                    display: flex; justify-content: space-between;
                    align-items: center; padding: .5rem 0;
                    border-bottom: 1px solid var(--dg-border);
                    font-size: .875rem;
                }
                .dg-info-row:last-child { border-bottom: none; }
                .dg-info-row__label { color: var(--dg-muted); }
                .dg-info-row__value { font-weight: 600; color: var(--dg-text); }

                /* ── Descripción ─────────────────────────────────── */
                .dg-desc-card {
                    background: var(--dg-surface);
                    border: 1px solid var(--dg-border);
                    border-radius: var(--dg-radius);
                    padding: 1.25rem 1.5rem;
                    box-shadow: var(--dg-shadow);
                    font-size: .875rem; color: var(--dg-text); line-height: 1.6;
                }

                /* ── Botón volver ────────────────────────────────── */
                .dg-back {
                    display: inline-flex; align-items: center; gap: .4rem;
                    color: var(--dg-muted); font-size: .82rem;
                    text-decoration: none; margin-bottom: 1rem;
                    transition: color .15s;
                }
                .dg-back:hover { color: var(--dg-primary); }</style>
            <div class="dg-page pb-5">
                <div class="container-fluid px-0 px-md-0">
                    <!-- Hero -->
                    <div class="dg-project-hero">
                        <a href="/digitalizacion/v1/dashboard" class="dg-back" style="color: rgba(255,255,255,.7);">
                            <i class="fa fa-arrow-left" />
                            Volver al dashboard
                        </a>
                        <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                            <div>
                                <h2>
                                    <t t-esc="proyecto.name" />
                                </h2>
                                <span class="dg-status">
                                    <i class="fa fa-circle" style="font-size:.5rem;" />
                                    <t t-esc="proyecto.state.capitalize() if proyecto.state else 'Activo'" />
                                </span>
                                <div class="dg-dates">
                                    <i class="fa fa-calendar me-1" />
                                    <t t-esc="proyecto.fecha_inicio" />
                                    —
                                    <t t-if="proyecto.fecha_fin_estimada">
                                        <t t-esc="proyecto.fecha_fin_estimada" />
                                    </t>
                                    <t t-else="">Sin fecha fin</t>
                                </div>
                            </div>
                        </div>
                        <!-- Barra de progreso si hay meta -->
                        <t t-if="proyecto.meta_escaneos and proyecto.meta_escaneos > 0">
                            <div class="dg-hero-progress">
                                <div class="dg-hero-progress__label">
                                    <span>Progreso del proyecto</span>
                                    <span>
                                        <t t-esc="'%.1f' % proyecto.progreso" />
                                        %
                                        (
                                        <t t-esc="proyecto.total_escaneos" />
                                        /
                                        <t t-esc="proyecto.meta_escaneos" />
                                        esc.)
                                    </span>
                                </div>
                                <div class="dg-hero-progress__bar">
                                    <div t-attf-style="width: #{proyecto.progreso}%" class="dg-hero-progress__fill" />
                                </div>
                            </div>
                        </t>
                    </div>
                    <div class="px-3 px-md-4">
                        <t t-if="notifications">
                            <t t-foreach="notifications" t-as="noti">
                                <div t-attf-class="alert alert-#{noti['type']} alert-dismissible fade show mt-3" role="alert">
                                    <t t-esc="noti['message']" />
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" />
                                </div>
                            </t>
                        </t>
                        <!-- Acciones principales -->
                        <div class="row g-3 mb-4 mt-1">
                            <div class="col-12 col-md-6">
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{proyecto.id}/form" class="dg-action-card">
                                    <div class="dg-action-card__icon dg-action-card__icon--primary">
                                        <i class="fa fa-pencil-square-o" />
                                    </div>
                                    <div>
                                        <div class="dg-action-card__title">Registrar producción</div>
                                        <div class="dg-action-card__desc">Carga el trabajo de hoy del equipo</div>
                                    </div>
                                    <i class="fa fa-chevron-right dg-action-card__arrow" />
                                </a>
                            </div>
                            <div class="col-12 col-md-6">
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{proyecto.id}/miembros" class="dg-action-card">
                                    <div class="dg-action-card__icon dg-action-card__icon--green">
                                        <i class="fa fa-users" />
                                    </div>
                                    <div>
                                        <div class="dg-action-card__title">Gestionar equipo</div>
                                        <div class="dg-action-card__desc">Ver y agregar digitalizadores</div>
                                    </div>
                                    <i class="fa fa-chevron-right dg-action-card__arrow" />
                                </a>
                            </div>
                        </div>
                        <!-- Info + descripción -->
                        <div class="row g-3">
                            <div class="col-12 col-md-5">
                                <div class="dg-info-card">
                                    <div class="dg-info-card__title">
                                        <i class="fa fa-info-circle" />
                                        Información
                                    </div>
                                    <div class="dg-info-row">
                                        <span class="dg-info-row__label">Miembros</span>
                                        <span class="dg-info-row__value">
                                            <t t-esc="proyecto.total_miembros" />
                                        </span>
                                    </div>
                                    <div class="dg-info-row">
                                        <span class="dg-info-row__label">Registros totales</span>
                                        <span class="dg-info-row__value">
                                            <t t-esc="proyecto.total_registros" />
                                        </span>
                                    </div>
                                    <div class="dg-info-row">
                                        <span class="dg-info-row__label">Escaneos acumulados</span>
                                        <span class="dg-info-row__value">
                                            <t t-esc="proyecto.total_escaneos" />
                                        </span>
                                    </div>
                                    <t t-if="proyecto.duracion_estimada">
                                        <div class="dg-info-row">
                                            <span class="dg-info-row__label">Duración estimada</span>
                                            <span class="dg-info-row__value">
                                                <t t-esc="proyecto.duracion_estimada" />
                                                días
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="col-12 col-md-7">
                                <t t-if="proyecto.description">
                                    <div class="dg-desc-card h-100">
                                        <div class="dg-info-card__title" style="margin-bottom:.75rem;">
                                            <i class="fa fa-align-left" />
                                            Descripción
                                        </div>
                                        <t t-esc="proyecto.description" />
                                    </div>
                                </t>
                                <t t-if="not proyecto.description">
                                    <div class="dg-desc-card h-100 d-flex align-items-center justify-content-center" style="color: var(--dg-muted); font-style: italic;">Sin descripción registrada</div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>