<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="digitalizacion_portal_proyecto_detalle" name="Detalle del Proyecto">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <div class="o_digitalizacion_page pb-5">
                <div class="container-fluid px-0 px-md-0">
                    <!-- Hero -->
                    <div class="o_digitalizacion_project-hero">
                        <a href="/digitalizacion/v1/dashboard" class="o_digitalizacion_back" style="color: rgba(255,255,255,.7);">
                            <i class="fa fa-arrow-left" />
                            Volver al dashboard
                        </a>
                        <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                            <div>
                                <h2>
                                    <t t-esc="proyecto.name" />
                                </h2>
                                <span class="o_digitalizacion_status">
                                    <i class="fa fa-circle" style="font-size:.5rem;" />
                                    <t t-esc="proyecto.state.capitalize() if proyecto.state else 'Activo'" />
                                </span>
                                <div class="o_digitalizacion_dates">
                                    <i class="fa fa-calendar me-1" />
                                    <t t-esc="proyecto.fecha_inicio" />
                                    —
                                    <t t-if="proyecto.fecha_fin_estimada">
                                        <t t-esc="proyecto.fecha_fin_estimada" />
                                    </t>
                                    <t t-else="">Sin fecha fin</t>
                                </div>
                            </div>
                        </div>
                        <!-- Barra de progreso si hay meta -->
                        <t t-if="proyecto.meta_escaneos and proyecto.meta_escaneos > 0">
                            <div class="o_digitalizacion_hero-progress">
                                <div class="o_digitalizacion_hero-progress__label">
                                    <span>Progreso del proyecto</span>
                                    <span>
                                        <t t-esc="'%.1f' % proyecto.progreso" />
                                        %
                                        (
                                        <t t-esc="proyecto.total_escaneos" />
                                        /
                                        <t t-esc="proyecto.meta_escaneos" />
                                        esc.)
                                    </span>
                                </div>
                                <div class="o_digitalizacion_hero-progress__bar">
                                    <div t-attf-style="width: #{proyecto.progreso}%" class="o_digitalizacion_hero-progress__fill" />
                                </div>
                            </div>
                        </t>
                    </div>
                    <div class="px-3 px-md-4">
                        <t t-if="notifications">
                            <t t-foreach="notifications" t-as="noti">
                                <div t-attf-class="alert alert-#{noti['type']} alert-dismissible fade show mt-3" role="alert">
                                    <t t-esc="noti['message']" />
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" />
                                </div>
                            </t>
                        </t>
                        <!-- Acciones principales -->
                        <div class="row g-3 mb-4 mt-1">
                            <div class="col-12 col-md-6">
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{proyecto.id}/form" class="o_digitalizacion_action-card">
                                    <div class="o_digitalizacion_action-card__icon o_digitalizacion_action-card__icon--primary">
                                        <i class="fa fa-pencil-square-o" />
                                    </div>
                                    <div>
                                        <div class="o_digitalizacion_action-card__title">Registrar producción</div>
                                        <div class="o_digitalizacion_action-card__desc">Carga el trabajo de hoy del equipo</div>
                                    </div>
                                    <i class="fa fa-chevron-right o_digitalizacion_action-card__arrow" />
                                </a>
                            </div>
                            <div class="col-12 col-md-6">
                                <a t-attf-href="/digitalizacion/v1/proyectos/#{proyecto.id}/miembros" class="o_digitalizacion_action-card">
                                    <div class="o_digitalizacion_action-card__icon o_digitalizacion_action-card__icon--green">
                                        <i class="fa fa-users" />
                                    </div>
                                    <div>
                                        <div class="o_digitalizacion_action-card__title">Gestionar equipo</div>
                                        <div class="o_digitalizacion_action-card__desc">Ver y agregar digitalizadores</div>
                                    </div>
                                    <i class="fa fa-chevron-right o_digitalizacion_action-card__arrow" />
                                </a>
                            </div>
                        </div>
                        <!-- Info + descripción -->
                        <div class="row g-3">
                            <div class="col-12 col-md-5">
                                <div class="o_digitalizacion_info-card">
                                    <div class="o_digitalizacion_info-card__title">
                                        <i class="fa fa-info-circle" />
                                        Información
                                    </div>
                                    <div class="o_digitalizacion_info-row">
                                        <span class="o_digitalizacion_info-row__label">Miembros</span>
                                        <span class="o_digitalizacion_info-row__value">
                                            <t t-esc="proyecto.total_miembros" />
                                        </span>
                                    </div>
                                    <div class="o_digitalizacion_info-row">
                                        <span class="o_digitalizacion_info-row__label">Registros totales</span>
                                        <span class="o_digitalizacion_info-row__value">
                                            <t t-esc="proyecto.total_registros" />
                                        </span>
                                    </div>
                                    <div class="o_digitalizacion_info-row">
                                        <span class="o_digitalizacion_info-row__label">Escaneos acumulados</span>
                                        <span class="o_digitalizacion_info-row__value">
                                            <t t-esc="proyecto.total_escaneos" />
                                        </span>
                                    </div>
                                    <t t-if="proyecto.duracion_estimada">
                                        <div class="o_digitalizacion_info-row">
                                            <span class="o_digitalizacion_info-row__label">Duración estimada</span>
                                            <span class="o_digitalizacion_info-row__value">
                                                <t t-esc="proyecto.duracion_estimada" />
                                                días
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="col-12 col-md-7">
                                <t t-if="proyecto.description">
                                    <div class="o_digitalizacion_desc-card h-100">
                                        <div class="o_digitalizacion_info-card__title" style="margin-bottom:.75rem;">
                                            <i class="fa fa-align-left" />
                                            Descripción
                                        </div>
                                        <t t-esc="proyecto.description" />
                                    </div>
                                </t>
                                <t t-if="not proyecto.description">
                                    <div class="o_digitalizacion_desc-card h-100 d-flex align-items-center justify-content-center" style="color: var(--o_digitalizacion_muted); font-style: italic;">Sin descripción registrada</div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>