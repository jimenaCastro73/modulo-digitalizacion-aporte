<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         portal_proyecto_templates.xml
         Detalle del proyecto para el Líder:
         - Progreso hacia la meta
         - Datos generales del proyecto
         - Accesos rápidos: registrar producción y ver equipo
         ================================================================ -->
    <template id="digitalizacion_portal_proyecto_detalle" name="Portal: detalle del proyecto">
        <t t-call="portal.portal_layout">
            <!-- Notificaciones flash -->
            <t t-if="notifications">
                <div class="container mt-3">
                    <t t-foreach="notifications" t-as="notif">
                        <div t-attf-class="alert alert-{{ notif['type'] }} alert-dismissible" role="alert">
                            <t t-esc="notif['message']" />
                            <button type="button" class="btn-close" data-bs-dismiss="alert" />
                        </div>
                    </t>
                </div>
            </t>
            <div class="container py-4">
                <!-- Cabecera -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h2 class="mb-1">
                                    <t t-esc="proyecto.name" />
                                </h2>
                                <span t-attf-class="badge #{'bg-success' if proyecto.state == 'activo' else 'bg-secondary'}">
                                    <t t-esc="'Activo' if proyecto.state == 'activo' else 'Inactivo'" />
                                </span>
                            </div>
                            <!-- Acciones rápidas -->
                            <div class="d-flex gap-2 flex-wrap">
                                <a t-attf-href="/digitalizacion/v1/proyectos/{{ proyecto.id }}/form" class="btn btn-primary">
                                    <i class="fa fa-plus me-1" />
                                    Registrar producción
                                </a>
                                <a t-attf-href="/digitalizacion/v1/proyectos/{{ proyecto.id }}/miembros" class="btn btn-outline-secondary">
                                    <i class="fa fa-users me-1" />
                                    Ver equipo
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Barra de progreso -->
                <t t-if="proyecto.meta_escaneos > 0">
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="fw-semibold">Progreso del proyecto</span>
                                <span class="text-muted">
                                    <t t-esc="proyecto.total_escaneos" />
                                    /
                                    <t t-esc="proyecto.meta_escaneos" />
                                    escaneos
                                    (
                                    <t t-esc="'%.1f' % proyecto.progreso" />
                                    %)
                                </span>
                            </div>
                            <div class="progress" style="height: 20px;">
                                <div t-attf-style="width: {{ min(proyecto.progreso, 100) }}%" t-attf-aria-valuenow="{{ proyecto.progreso }}" class="progress-bar bg-success" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                                    <t t-if="proyecto.progreso >= 15">
                                        <t t-esc="'%.1f' % proyecto.progreso" />
                                        %
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
                <!-- KPIs del proyecto -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <div class="display-6 fw-bold text-primary">
                                    <t t-esc="proyecto.total_miembros" />
                                </div>
                                <div class="text-muted small">Miembros activos</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <div class="display-6 fw-bold text-success">
                                    <t t-esc="proyecto.total_escaneos" />
                                </div>
                                <div class="text-muted small">Escaneos totales</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <div class="display-6 fw-bold text-info">
                                    <t t-esc="proyecto.total_registros" />
                                </div>
                                <div class="text-muted small">Registros</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <div class="display-6 fw-bold text-warning">
                                    <t t-esc="proyecto.duracion_estimada or '—'" />
                                </div>
                                <div class="text-muted small">Días estimados</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Datos del proyecto -->
                <div class="card">
                    <div class="card-header fw-semibold">Información del proyecto</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted">Fecha inicio</dt>
                                    <dd class="col-sm-7">
                                        <t t-esc="proyecto.fecha_inicio" />
                                    </dd>
                                    <dt class="col-sm-5 text-muted">Fecha fin est.</dt>
                                    <dd class="col-sm-7">
                                        <t t-esc="proyecto.fecha_fin_estimada or '—'" />
                                    </dd>
                                    <dt class="col-sm-5 text-muted">Meta escaneos</dt>
                                    <dd class="col-sm-7">
                                        <t t-esc="proyecto.meta_escaneos or '—'" />
                                    </dd>
                                </dl>
                            </div>
                            <div t-if="proyecto.description" class="col-md-6">
                                <p class="text-muted small mb-1 fw-semibold">Descripción</p>
                                <p class="mb-0">
                                    <t t-esc="proyecto.description" />
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>