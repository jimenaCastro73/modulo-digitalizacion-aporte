<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         portal_miembros_templates.xml
         Vista de miembros del equipo para el Líder (SOLO LECTURA).
         Incluye:
           1. Gráfico de barras apiladas por etapa (CSS puro, sin librerías)
           2. Tabla heatmap con conteo exacto por miembro/etapa
           3. Lista de miembros activos con estado
         El Administrador gestiona el equipo desde el backoffice.
         ================================================================ -->
    <!-- Colores por etapa — alineados con colores del controller -->
    <!-- Limpieza:#378ADD Ordenado:#639922 Digitalizado:#1D9E75 Editado:#EF9F27 Indexado:#7F77DD -->
    <template id="digitalizacion_portal_miembros_equipo" name="Portal: equipo del proyecto">
        <t t-call="portal.portal_layout">
            <!-- Notificaciones flash -->
            <t t-if="notifications">
                <div class="container mt-3">
                    <t t-foreach="notifications" t-as="notif">
                        <div t-attf-class="alert alert-{{ notif['type'] }} alert-dismissible" role="alert">
                            <t t-esc="notif['message']" />
                            <button type="button" class="btn-close" data-bs-dismiss="alert" />
                        </div>
                    </t>
                </div>
            </t>
            <div class="container py-4">
                <!-- Cabecera -->
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div>
                        <h3 class="mb-0">Equipo</h3>
                        <p class="text-muted mb-0">
                            <t t-esc="proyecto.name" />
                            ·
                            <t t-esc="len(miembros)" />
                            miembro(s) activo(s)
                        </p>
                    </div>
                    <a t-attf-href="/digitalizacion/v1/proyectos/{{ proyecto.id }}" class="btn btn-outline-secondary btn-sm">
                        <i class="fa fa-arrow-left me-1" />
                        Volver al proyecto
                    </a>
                </div>
                <!-- ═══════════════════════════════════════════════════
                     GRÁFICO: BARRAS APILADAS POR ETAPA
                     Datos pasados desde el controller como 'participacion'
                     CSS puro, sin librerías externas
                ════════════════════════════════════════════════════ -->
                <t t-if="participacion and participacion.get('miembros')">
                    <div class="card mb-4">
                        <div class="card-header fw-semibold">Participación por etapa</div>
                        <div class="card-body">
                            <!-- Leyenda de colores -->
                            <div class="d-flex flex-wrap gap-3 mb-3">
                                <t t-foreach="etapas_con_color" t-as="ec">
                                    <div class="d-flex align-items-center gap-1">
                                        <div t-attf-style="width:12px;height:12px;border-radius:2px;background:{{ ec['color'] }};" style="width:12px;height:12px;border-radius:2px;" />
                                        <small class="text-muted">
                                            <t t-esc="ec['nombre']" />
                                        </small>
                                    </div>
                                </t>
                            </div>
                            <!-- Barras apiladas -->
                            <t t-foreach="participacion['miembros']" t-as="m">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <!-- Nombre del miembro -->
                                    <div style="width:110px;flex-shrink:0;text-align:right;">
                                        <small class="text-muted text-truncate d-block">
                                            <t t-esc="m['nombre'].split()[0] if m['nombre'] else '—'" />
                                        </small>
                                    </div>
                                    <!-- Barra apilada -->
                                    <div class="flex-grow-1" style="height:24px;border-radius:4px;overflow:hidden;display:flex;background:#f0f0f0;">
                                        <t t-foreach="m['segmentos']" t-as="seg">
                                            <t t-if="seg['count'] > 0">
                                                <!-- Buscar color del segmento -->
                                                <t t-foreach="etapas_con_color" t-as="ec">
                                                    <t t-if="ec['nombre'] == seg['etapa']">
                                                        <div t-attf-style="width:{{ seg['pct'] }}%;background:{{ ec['color'] }};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:#fff;min-width:0;" t-attf-title="{{ seg['etapa'] }}: {{ seg['count'] }} registros">
                                                            <t t-if="seg['pct'] >= 12">
                                                                <t t-esc="seg['count']" />
                                                            </t>
                                                        </div>
                                                    </t>
                                                </t>
                                            </t>
                                        </t>
                                    </div>
                                    <!-- Total -->
                                    <div style="width:32px;flex-shrink:0;">
                                        <small class="text-muted">
                                            <t t-esc="m['total']" />
                                        </small>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                    <!-- ═══════════════════════════════════════════════════
                         TABLA HEATMAP — conteo exacto por miembro y etapa
                    ════════════════════════════════════════════════════ -->
                    <div class="card mb-4">
                        <div class="card-header fw-semibold">Detalle por miembro</div>
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Miembro</th>
                                        <t t-foreach="participacion['etapas']" t-as="etapa">
                                            <th class="text-center">
                                                <small>
                                                    <t t-esc="etapa" />
                                                </small>
                                            </th>
                                        </t>
                                        <th class="text-center fw-bold">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="participacion['miembros']" t-as="m">
                                        <tr>
                                            <td>
                                                <small>
                                                    <t t-esc="m['nombre']" />
                                                </small>
                                            </td>
                                            <t t-foreach="participacion['etapas']" t-as="etapa">
                                                <t t-set="cnt" t-value="m['por_etapa'].get(etapa, 0)" />
                                                <td class="text-center">
                                                    <t t-if="cnt == 0">
                                                        <span class="text-muted">—</span>
                                                    </t>
                                                    <t t-else="">
                                                        <!-- Color según intensidad relativa al total del miembro -->
                                                        <t t-set="pct" t-value="(cnt / m['total'] * 100) if m['total'] else 0" />
                                                        <span t-attf-style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:500;background:{{ '#E6F1FB' if pct < 25 else ('#85B7EB' if pct < 50 else '#185FA5') }};color:{{ '#0C447C' if pct < 25 else ('#042C53' if pct < 50 else '#E6F1FB') }};">
                                                            <t t-esc="cnt" />
                                                        </span>
                                                    </t>
                                                </td>
                                            </t>
                                            <td class="text-center fw-bold">
                                                <t t-esc="m['total']" />
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
                <!-- Sin datos aún -->
                <t t-if="not participacion or not participacion.get('miembros')">
                    <div class="alert alert-info mb-4">
                        <i class="fa fa-info-circle me-1" />
                        Aún no hay registros de trabajo para este proyecto.
                        El gráfico aparecerá cuando el Líder registre la primera jornada.
                    </div>
                </t>
                <!-- ═══════════════════════════════════════════════════
                     LISTA DE MIEMBROS (SOLO LECTURA)
                ════════════════════════════════════════════════════ -->
                <div class="card">
                    <div class="card-header fw-semibold">
                        Miembros del equipo
                        <small class="text-muted ms-2">Solo lectura — el administrador gestiona el equipo</small>
                    </div>
                    <t t-if="miembros">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Integración</th>
                                        <th>Estado</th>
                                        <th class="text-center">Rol</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="miembros" t-as="m">
                                        <tr>
                                            <td>
                                                <span class="fw-semibold">
                                                    <t t-esc="m.partner_id.name" />
                                                </span>
                                            </td>
                                            <td class="text-muted">
                                                <t t-esc="m.fecha_integracion" />
                                            </td>
                                            <td>
                                                <t t-if="m.fecha_salida">
                                                    <span class="badge bg-secondary">
                                                        Salida:
                                                        <t t-esc="m.fecha_salida" />
                                                    </span>
                                                </t>
                                                <t t-elif="m.active">
                                                    <span class="badge bg-success">Activo</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge bg-warning text-dark">Inactivo</span>
                                                </t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="m.es_lider">
                                                    <span class="badge bg-primary">
                                                        <i class="fa fa-star me-1" />
                                                        Líder
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted small">Digitalizador</span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="card-body text-center text-muted py-4">
                            <i class="fa fa-users fa-2x mb-2 d-block" />
                            No hay miembros activos en este proyecto.
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>