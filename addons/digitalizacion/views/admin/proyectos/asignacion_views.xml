<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         asignacion_views.xml — Vistas del backend para digitalizacion.asignacion
         Modelo T-04 · Asignación de Líder a Proyecto
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)
         ================================================================ -->
    <!-- 1. VISTA LISTA -->
    <record id="digitalizacion_asignacion_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.asignacion.list</field>
        <field name="model">digitalizacion.asignacion</field>
        <field name="arch" type="xml">
            <tree string="Asignaciones de Líder" default_order="fecha_asignacion desc" decoration-muted="not active">
                <field name="lider_id" string="Líder" />
                <field name="proyecto_id" string="Proyecto" />
                <field name="fecha_asignacion" string="Fecha asignación" />
                <field name="active" string="Activo" widget="boolean_toggle" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA FORMULARIO -->
    <record id="digitalizacion_asignacion_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.asignacion.form</field>
        <field name="model">digitalizacion.asignacion</field>
        <field name="arch" type="xml">
            <form string="Asignación de Líder">
                <header>
                    <button name="action_desactivar" string="Desactivar" type="object" class="btn-secondary" invisible="not active" />
                    <button name="action_activar" string="Activar" type="object" class="btn-primary" invisible="active" />
                </header>
                <field name="active" widget="boolean_toggle" invisible="1" />
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="active">
                        <i class="fa fa-exclamation-triangle me-1" />
                        Esta asignación está inactiva. El líder no tiene acceso
                        al proyecto en el portal.
                    </div>
                    <group>
                        <group string="Asignación">
                            <field name="lider_id" string="Líder" domain="[('share', '=', True), ('active', '=', True)]" options="{'no_create': True}" required="1" />
                            <field name="proyecto_id" string="Proyecto" domain="[('active', '=', True)]" options="{'no_create': True}" required="1" />
                            <field name="fecha_asignacion" string="Fecha de asignación" />
                        </group>
                        <group string="Estado">
                            <field name="active" string="Activo" widget="boolean_toggle" />
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle me-1" />
                        Al crear una asignación, el líder aparecerá automáticamente
                        como miembro del equipo en el proyecto.
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 3. VISTA BÚSQUEDA -->
    <record id="digitalizacion_asignacion_view_search" model="ir.ui.view">
        <field name="name">digitalizacion.asignacion.search</field>
        <field name="model">digitalizacion.asignacion</field>
        <field name="arch" type="xml">
            <search string="Buscar asignaciones">
                <field name="lider_id" string="Líder" />
                <field name="proyecto_id" string="Proyecto" />
                <separator />
                <filter name="activas" string="Activas" domain="[('active', '=', True)]" />
                <filter name="inactivas" string="Inactivas" domain="[('active', '=', False)]" />
                <group string="Agrupar por" expand="0">
                    <filter name="group_proyecto" string="Proyecto" context="{'group_by': 'proyecto_id'}" />
                    <filter name="group_lider" string="Líder" context="{'group_by': 'lider_id'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- 4. ACCIÓN -->
    <record id="digitalizacion_asignacion_action" model="ir.actions.act_window">
        <field name="name">Asignar Líderes</field>
        <field name="res_model">digitalizacion.asignacion</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="digitalizacion_asignacion_view_search" />
        <field name="context">{'search_default_activas': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Asigna el primer líder a un proyecto</p>
            <p>El líder accede al portal web y registra la producción
                diaria de su equipo de digitalización.</p>
        </field>
    </record>
</odoo>