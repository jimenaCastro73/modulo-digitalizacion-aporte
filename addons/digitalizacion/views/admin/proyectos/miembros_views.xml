<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="view_miembro_proyecto_form_inline" model="ir.ui.view">
        <field name="name">digitalizacion.miembro_proyecto.form</field>
        <field name="model">digitalizacion.miembro_proyecto</field>
        <field name="arch" type="xml">
            <form string="Miembro del Proyecto">
                <header>
                    <button name="action_registrar_salida" string="Registrar Salida" type="object" class="btn-danger" invisible="fecha_salida" confirm="¿Registrar salida de este miembro? Se establecerá fecha_salida a fecha actual. Se desactivará el miembro. Si era líder, se perderá ese rol." />
                    <button name="action_reintegrar" string="Reintegrar" type="object" class="btn-success" invisible="not fecha_salida" confirm="¿Reintegrar a este miembro? Se limpiará la fecha_salida. Se reactivará el miembro." />
                </header>
                <sheet>
                    <!-- Alerta si el miembro tiene fecha de salida -->
                    <div class="alert alert-warning" role="alert" invisible="not fecha_salida">
                        <i class="fa fa-exclamation-triangle me-2" title="Advertencia" />
                        <strong>Miembro Inactivo</strong>
                        — Este miembro tiene fecha de salida registrada 
                        (
                        <field name="fecha_salida" />
                        ) y no puede generar nuevos registros.
                        <br />
                        Usa el botón
                        <strong>"Reintegrar"</strong>
                        si deseas reactivarlo.
                    </div>
                    <!-- Datos principales -->
                    <group name="info_basica" string="Información del Miembro">
                        <group>
                            <field name="partner_id" required="1" readonly="fecha_salida" />
                            <field name="proyecto_id" required="1" readonly="1" />
                        </group>
                        <group>
                            <field name="fecha_integracion" required="1" />
                            <field name="fecha_salida" readonly="1" />
                            <field name="es_lider" />
                            <field name="total_registros" readonly="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Vista Search -->
    <record id="view_miembro_proyecto_search" model="ir.ui.view">
        <field name="name">digitalizacion.miembro_proyecto.search</field>
        <field name="model">digitalizacion.miembro_proyecto</field>
        <field name="arch" type="xml">
            <search string="Buscar Miembros">
                <field name="partner_id" string="Nombre" />
                <field name="proyecto_id" string="Proyecto" />
                <filter name="activos" string="Activos" domain="[('fecha_salida', '=', False)]" />
                <filter name="inactivos" string="Inactivos" domain="[('fecha_salida', '!=', False)]" />
                <filter name="es_lider" string="Es Líder" domain="[('es_lider', '=', True)]" />
            </search>
        </field>
    </record>
</odoo>