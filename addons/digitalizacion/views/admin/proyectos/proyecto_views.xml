<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         proyecto_views.xml — Vistas del backend para digitalizacion.proyecto
         Modelo T-03 · Registro central de proyectos de digitalización
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)
         ================================================================ -->
    <!-- 1. VISTA LISTA -->
    <record id="digitalizacion_proyecto_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.list</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <tree string="Proyectos" default_order="fecha_inicio desc" decoration-muted="not active" decoration-warning="state == 'inactivo'">
                <field name="name" string="Proyecto" />
                <field name="fecha_inicio" string="Inicio" />
                <field name="fecha_fin_estimada" string="Fin estimado" optional="show" />
                <field name="duracion_estimada" string="Días" optional="hide" />
                <field name="state" string="Estado" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'inactivo'" />
                <field name="total_miembros" string="Miembros" optional="show" />
                <field name="total_registros" string="Registros" optional="show" />
                <field name="total_escaneos" string="Escaneos" optional="show" />
                <field name="progreso" string="Progreso" widget="progressbar" options="{'editable': false}" optional="show" />
                <field name="active" column_invisible="True" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA KANBAN -->
    <record id="digitalizacion_proyecto_view_kanban" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.kanban</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name" />
                <field name="state" />
                <field name="progreso" />
                <field name="total_miembros" />
                <field name="total_escaneos" />
                <field name="meta_escaneos" />
                <field name="color" />
                <field name="active" />
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill o_res_partner_kanban">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <field name="name" />
                                    </div>
                                    <div class="o_secondary">
                                        <field name="state" widget="badge" />
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_card_content">
                                <div class="row">
                                    <div class="col-6">
                                        <span class="o_text_overflow">
                                            <i class="fa fa-users me-1" />
                                            <t t-esc="record.total_miembros.value" />
                                            miembros
                                        </span>
                                    </div>
                                    <div class="col-6 text-end">
                                        <span>
                                            <i class="fa fa-files-o me-1" />
                                            <t t-esc="record.total_escaneos.value" />
                                            escaneos
                                        </span>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <field name="progreso" widget="progressbar" options="{'editable': false, 'max_value': 100}" />
                                </div>
                            </div>
                            <div class="o_kanban_card_footer">
                                <field name="lider_ids" widget="many2many_avatar_user" />
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- 3. VISTA FORMULARIO -->
    <record id="digitalizacion_proyecto_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.form</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <form string="Proyecto de Digitalización">
                <header>
                    <button name="action_inactivar" string="Marcar inactivo" type="object" class="btn-secondary" invisible="state == 'inactivo'" />
                    <button name="action_activar" string="Reactivar" type="object" class="btn-primary" invisible="state == 'activo'" />
                    <button name="action_archivar" string="Archivar" type="object" class="btn-secondary" invisible="not active" />
                    <field name="state" widget="statusbar" statusbar_visible="activo,inactivo" />
                </header>
                <div name="button_box" class="oe_button_box">
                    <button name="action_ver_miembros" type="object" class="oe_stat_button" icon="fa-users">
                        <field name="total_miembros" string="Miembros" widget="statinfo" />
                    </button>
                    <button name="action_ver_registros" type="object" class="oe_stat_button" icon="fa-list-ul">
                        <field name="total_registros" string="Registros" widget="statinfo" />
                    </button>
                    <button name="action_ver_registros" type="object" class="oe_stat_button" icon="fa-camera" invisible="total_escaneos == 0">
                        <field name="total_escaneos" string="Escaneos" widget="statinfo" />
                    </button>
                </div>
                <field name="active" widget="boolean_toggle" invisible="1" />
                <sheet>
                    <div class="oe_title">
                        <label string="Nombre del proyecto" for="name" />
                        <h1>
                            <field name="name" placeholder="Ej: Inprema 2026, Centro Cívico..." required="1" />
                        </h1>
                    </div>
                    <!-- Barra de progreso destacada -->
                    <div class="o_field_widget o_field_progressbar mb-3" invisible="meta_escaneos == 0">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-bold">Progreso del proyecto</span>
                            <span>
                                <field name="total_escaneos" readonly="1" />
                                /
                                <field name="meta_escaneos" />
                                escaneos
                            </span>
                        </div>
                        <field name="progreso" widget="progressbar" options="{'editable': false, 'max_value': 100}" />
                    </div>
                    <group>
                        <group string="Información general">
                            <field name="fecha_inicio" required="1" />
                            <field name="fecha_fin_estimada" />
                            <field name="duracion_estimada" readonly="1" invisible="not fecha_fin_estimada" />
                            <field name="meta_escaneos" string="Meta de escaneos" help="Cantidad objetivo de escaneos para calcular el progreso." />
                        </group>
                        <group string="Estado">
                            <field name="state" widget="radio" options="{'horizontal': true}" />
                            <field name="color" string="Color kanban" widget="color_picker" invisible="1" />
                        </group>
                    </group>
                    <field name="description" string="Descripción" placeholder="Alcance, contexto o notas del proyecto..." />
                    <notebook>
                        <!-- Pestaña: Líderes -->
                        <page name="lideres" string="Líderes asignados">
                            <field name="asignacion_ids" context="{'default_proyecto_id': active_id}">
                                <tree string="Asignaciones de líder" editable="bottom">
                                    <field name="lider_id" string="Líder" />
                                    <field name="fecha_asignacion" string="Fecha asignación" />
                                    <field name="active" string="Activo" widget="boolean_toggle" />
                                </tree>
                            </field>
                        </page>
                        <!-- Pestaña: Equipo -->
                        <page name="miembros" string="Equipo">
                            <field name="miembro_ids" context="{'default_proyecto_id': active_id}">
                                <tree string="Miembros del equipo" decoration-muted="not active or fecha_salida">
                                    <field name="partner_id" string="Digitalizador" />
                                    <field name="fecha_integracion" string="Integración" />
                                    <field name="fecha_salida" string="Salida" optional="show" />
                                    <field name="es_lider" string="Líder" widget="boolean_toggle" />
                                    <field name="total_registros" string="Registros" optional="show" />
                                    <field name="active" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <!-- Pestaña: Estadísticas -->
                        <page name="estadisticas" string="Estadísticas" invisible="total_registros == 0">
                            <group>
                                <group string="Producción acumulada">
                                    <field name="total_escaneos" string="Total escaneos (hojas digitales)" readonly="1" />
                                    <field name="progreso" string="Progreso hacia la meta (%)" readonly="1" />
                                </group>
                                <group string="Equipo">
                                    <field name="total_miembros" string="Miembros activos" readonly="1" />
                                    <field name="total_registros" string="Registros de trabajo" readonly="1" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 4. VISTA BÚSQUEDA -->
    <record id="digitalizacion_proyecto_view_search" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.search</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <search string="Buscar proyectos">
                <field name="name" string="Proyecto" filter_domain="[('name', 'ilike', self)]" />
                <separator />
                <filter name="activos" string="Activos" domain="[('state', '=', 'activo')]" />
                <filter name="inactivos" string="Inactivos" domain="[('state', '=', 'inactivo')]" />
                <separator />
                <filter name="archivados" string="Archivados" domain="[('active', '=', False)]" />
                <group string="Agrupar por" expand="0">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}" />
                    <filter name="group_mes" string="Mes de inicio" context="{'group_by': 'fecha_inicio:month'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- 5. ACCIÓN -->
    <record id="digitalizacion_proyecto_action" model="ir.actions.act_window">
        <field name="name">Proyectos</field>
        <field name="res_model">digitalizacion.proyecto</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="digitalizacion_proyecto_view_search" />
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea el primer proyecto de digitalización</p>
            <p>Los proyectos agrupan el trabajo del equipo. Asigna un líder
                y agrega los digitalizadores para comenzar a registrar producción.</p>
        </field>
    </record>
</odoo>