<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree -->
    <record id="digitalizacion_proyecto_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.tree</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <tree string="Proyectos de Digitalización" default_order="fecha_inicio desc, name asc" decoration-muted="state == 'pausado'" decoration-success="state == 'en_curso'" decoration-info="state == 'finalizado'" decoration-danger="active == False">
                <field name="name" string="Proyecto" />
                <field name="fecha_inicio" string="Inicio" widget="date" />
                <field name="fecha_fin_estimada" string="Fin Estimado" widget="date" />
                <field name="state" string="Estado" widget="badge" decoration-success="state == 'en_curso'" decoration-warning="state == 'pausado'" decoration-info="state == 'finalizado'" />
                <field name="total_miembros" string="Miembros" sum="Total" />
                <field name="total_escaneos" string="Escaneos" sum="Total" />
                <field name="total_registros" string="Registros" sum="Total" optional="hide" />
                <field name="active" string="Archivado" widget="boolean_toggle" optional="hide" />
            </tree>
        </field>
    </record>
    <!-- Vista Form -->
    <record id="digitalizacion_proyecto_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.form</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <form string="Proyecto de Digitalización">
                <!-- HEADER: Botones de acción y estado -->
                <header>
                    <button name="action_reactivar" string="Iniciar / Reanudar" type="object" class="btn-primary" invisible="state == 'en_curso'" />
                    <button name="action_pausar" string="Pausar (Standby)" type="object" class="btn-secondary" invisible="state != 'en_curso'" />
                    <button name="action_finalizar" string="Finalizar Proyecto" type="object" class="btn-info" confirm="¿Confirmas que se han terminado los escaneos de este proyecto?" invisible="state == 'finalizado'" />
                    <!-- Botones de Archivar/Desarchivar (soft delete) -->
                    <button name="toggle_active" string="Archivar Proyecto" type="object" class="btn-secondary" invisible="not active" confirm="¿Archivar este proyecto? Los registros históricos se conservarán y podrás desarchivarlo más tarde." />
                    <button name="toggle_active" string="Desarchivar Proyecto" type="object" class="btn-primary" invisible="active" />
                    <!-- Statusbar de estado -->
                    <field name="state" widget="statusbar" statusbar_visible="en_curso,pausado,finalizado" />
                </header>
                <sheet>
                    <!-- Título del proyecto -->
                    <div class="oe_title">
                        <label string="Nombre del Proyecto" for="name" />
                        <h1>
                            <field name="name" placeholder="Ej: Inprema 2026, Centro Cívico..." />
                        </h1>
                        <!-- Badge de archivado visible -->
                        <field name="active" invisible="1" />
                        <div invisible="active" class="alert alert-warning mt-2" role="alert">
                            <i class="fa fa-archive me-2" title="Icono Archivado" />
                            <strong>Proyecto Archivado</strong>
                            — Este proyecto está inactivo. Usa el botón "Desarchivar" para reactivarlo.
                        </div>
                    </div>
                    <!-- Datos generales y KPIs -->
                    <group name="grupo_principal">
                        <group name="datos_generales" string="Datos Generales">
                            <field name="fecha_inicio" required="1" />
                            <field name="fecha_fin_estimada" />
                            <field name="duracion_estimada" readonly="1" />
                            <field name="description" placeholder="Descripción del alcance del proyecto..." />
                        </group>
                        <group name="kpis" string="Métricas del Proyecto">
                            <field name="total_miembros" string="Miembros Asignados" readonly="1" class="oe_inline" />
                            <field name="total_registros" string="Registros de Producción" readonly="1" />
                            <field name="total_escaneos" string="Total de Escaneos" readonly="1" />
                            <field name="etapa_dominante" string="Etapa con más producción" readonly="1" />
                        </group>
                    </group>
                    <!-- Notebook con pestañas -->
                    <notebook>
                        <!-- PESTAÑA 1: DASHBOARD ESPECÍFICO DEL PROYECTO -->
                        <page name="dashboard" string="Dashboard">
                            <div class="o_horizontal_separator mt-3 mb-4 text-primary fw-bold">
                                <i class="fa fa-dashboard me-2" title="Dashboard" />
                                RESUMEN OPERATIVO DEL PROYECTO
                            </div>
                            <!-- Tarjetas de KPIs -->
                            <div class="row text-center mb-4">
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0 bg-light p-3 h-100">
                                        <div class="text-muted small text-uppercase fw-bold mb-2">
                                            <i class="fa fa-users me-1" title="Equipo" />
                                            Equipo
                                        </div>
                                        <div class="h2 fw-bold text-primary mb-0">
                                            <field name="total_miembros" readonly="1" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0 bg-light p-3 h-100">
                                        <div class="text-muted small text-uppercase fw-bold mb-2">
                                            <i class="fa fa-camera me-1" title="Escaneos" />
                                            Escaneos
                                        </div>
                                        <div class="h2 fw-bold text-success mb-0">
                                            <field name="total_escaneos" readonly="1" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0 bg-light p-3 h-100">
                                        <div class="text-muted small text-uppercase fw-bold mb-2">
                                            <i class="fa fa-tasks me-1" title="Registros" />
                                            Registros
                                        </div>
                                        <div class="h2 fw-bold text-info mb-0">
                                            <field name="total_registros" readonly="1" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0 bg-light p-3 h-100">
                                        <div class="text-muted small text-uppercase fw-bold mb-2">
                                            <i class="fa fa-calendar me-1" title="Duración" />
                                            Duración
                                        </div>
                                        <div class="h2 fw-bold text-warning mb-0">
                                            <field name="duracion_estimada" readonly="1" />
                                            <small>días</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Botón para análisis gráfico -->
                            <div class="row justify-content-center mt-5">
                                <div class="col-md-8 text-center border-top pt-4">
                                    <p class="text-muted mb-4">
                                        <i class="fa fa-line-chart me-2" title="Análisis Gráfico" />
                                        Visualiza análisis de producción, análisis por etapa y rendimiento del equipo.
                                    </p>
                                    <button name="action_ver_analisis_grafico" type="object" class="btn btn-primary btn-lg shadow rounded-pill px-5" icon="fa-line-chart">
                                        <i class="fa fa-chart-line me-2" title="Análisis Gráfico" />
                                        <span class="fw-bold">ABRIR ANÁLISIS GRÁFICO</span>
                                    </button>
                                </div>
                            </div>
                        </page>
                        <!-- PESTAÑA 2: MIEMBROS DEL EQUIPO -->
                        <page name="equipo" string="Miembros del Equipo">
                            <field name="miembro_ids" context="{'default_proyecto_id': active_id}" nolabel="1">
                                <tree string="Miembros del Equipo" default_order="fecha_integracion desc" editable="bottom" decoration-muted="fecha_salida != False" decoration-success="es_lider == True">
                                    <field name="partner_id" string="Digitalizador" required="1" options="{'no_create': True}" />
                                    <field name="fecha_integracion" string="Ingreso" widget="date" required="1" />
                                    <field name="es_lider" string="Líder?" widget="boolean_toggle" />
                                    <field name="total_registros" string="Registros" sum="Total" readonly="1" />
                                    <field name="fecha_salida" string="Fecha Salida" widget="date" />
                                    <!-- Botón para Registrar Salida (solo visible si está activo - sin fecha_salida) -->
                                    <button name="action_registrar_salida" string="Salida" type="object" icon="fa-sign-out" class="btn-danger btn-sm" invisible="fecha_salida" confirm="¿Registrar salida de este miembro? Se establecerá fecha_salida = hoy." />
                                    <!-- Botón para Reintegrar (solo visible si está inactivo - tiene fecha_salida) -->
                                    <button name="action_reintegrar" string="Reintegrar" type="object" icon="fa-refresh" class="btn-success btn-sm" invisible="not fecha_salida" confirm="¿Reintegrar a este miembro? Se limpiará la fecha_salida." />
                                </tree>
                            </field>
                        </page>
                        <!-- PESTAÑA 3: BITÁCORA -->
                        <page name="bitacora" string="Bitácora">
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle me-2" title="Información" />
                                <strong>Registros de Producción:</strong>
                                Haz clic en cualquier registro para ver y editar sus detalles.
                                Solo el Administrador puede modificar registros existentes.
                            </div>
                            <field name="registro_ids" context="{'tree_view_ref': 'digitalizacion.digitalizacion_registro_view_tree', 'form_view_ref': 'digitalizacion.digitalizacion_registro_view_form', 'default_proyecto_id': active_id}" options="{'no_create': True}">
                                <tree string="Registros del Proyecto" default_order="fecha desc, hora desc" decoration-muted="produccion_principal == 0">
                                    <field name="fecha" width="110" />
                                    <field name="miembro_id" string="Digitalizador" />
                                    <field name="etapa_id" string="Etapa" />
                                    <field name="produccion_principal" string="Producción" sum="Total" />
                                    <field name="unidad_produccion" string="Unidad" />
                                    <field name="total_escaneos" string="Escaneos" sum="Total" optional="show" />
                                    <field name="referencia_cajas" optional="hide" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Vista Kanban -->
    <record id="digitalizacion_proyecto_view_kanban" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.kanban</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <!-- Campos necesarios para el template -->
                <field name="name" />
                <field name="state" />
                <field name="fecha_inicio" />
                <field name="fecha_fin_estimada" />
                <field name="total_miembros" />
                <field name="total_escaneos" />
                <field name="total_registros" />
                <field name="description" />
                <field name="active" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <!-- Icono según estado -->
                            <div class="o_kanban_image">
                                <t t-if="record.state.value == 'en_curso'">
                                    <i class="fa fa-play-circle-o text-success" style="font-size: 40px;" title="Proyecto en curso" />
                                </t>
                                <t t-elif="record.state.value == 'pausado'">
                                    <i class="fa fa-pause-circle-o text-warning" style="font-size: 40px;" title="Proyecto pausado" />
                                </t>
                                <t t-elif="record.state.value == 'finalizado'">
                                    <i class="fa fa-check-circle-o text-info" style="font-size: 40px;" title="Proyecto finalizado" />
                                </t>
                                <t t-else="">
                                    <i class="fa fa-folder-open-o text-muted" style="font-size: 40px;" title="Proyecto estado indefinido" />
                                </t>
                            </div>
                            <!-- Detalles de la tarjeta -->
                            <div class="oe_kanban_details">
                                <!-- Título -->
                                <strong class="o_kanban_record_title">
                                    <field name="name" />
                                </strong>
                                <!-- Badges de estado -->
                                <div class="mt-1 mb-2">
                                    <t t-if="record.state.value == 'en_curso'">
                                        <span class="badge bg-success">🚀 En curso</span>
                                    </t>
                                    <t t-elif="record.state.value == 'pausado'">
                                        <span class="badge bg-warning text-dark">⏸️ Pausa / Standby</span>
                                    </t>
                                    <t t-elif="record.state.value == 'finalizado'">
                                        <span class="badge bg-info">✅ Finalizado</span>
                                    </t>
                                    <!-- Badge de archivado -->
                                    <t t-if="record.active.value == False">
                                        <span class="badge bg-secondary ms-1">📦 Archivado</span>
                                    </t>
                                </div>
                                <!-- Métricas -->
                                <ul class="list-unstyled mt-2 mb-0">
                                    <li class="mb-1">
                                        <i class="fa fa-calendar fa-fw text-muted me-1" title="Inicio" />
                                        <small>
                                            Inicio:
                                            <field name="fecha_inicio" />
                                        </small>
                                    </li>
                                    <li t-if="record.fecha_fin_estimada.value" class="mb-1">
                                        <i class="fa fa-calendar-check-o fa-fw text-muted me-1" title="Fin estimado" />
                                        <small>
                                            Fin estimado:
                                            <field name="fecha_fin_estimada" />
                                        </small>
                                    </li>
                                    <li class="mb-1">
                                        <i class="fa fa-users fa-fw text-muted me-1" title="Equipo" />
                                        <small>
                                            Miembros:
                                            <field name="total_miembros" />
                                        </small>
                                    </li>
                                    <li class="mb-1">
                                        <i class="fa fa-camera fa-fw text-muted me-1" title="Escaneos" />
                                        <small>
                                            Escaneos:
                                            <field name="total_escaneos" />
                                        </small>
                                    </li>
                                    <li class="mb-1">
                                        <i class="fa fa-tasks fa-fw text-muted me-1" title="Registros" />
                                        <small>
                                            Registros:
                                            <field name="total_registros" />
                                        </small>
                                    </li>
                                </ul>
                                <!-- Descripción -->
                                <div t-if="record.description.value" class="mt-2 text-muted small">
                                    <i class="fa fa-align-left fa-fw me-1" title="Descripción" />
                                    <span t-esc="record.description.value.length > 80 ? record.description.value.slice(0, 80) + '...' : record.description.value" />
                                </div>
                                <!-- Pie de tarjeta -->
                                <div class="o_kanban_record_bottom mt-3 pt-2 border-top">
                                    <div class="oe_kanban_bottom_left">
                                        <small class="text-muted">
                                            <i class="fa fa-folder-open-o me-1" title="ID" />
                                            ID:
                                            <field name="id" />
                                        </small>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <t t-if="record.active.value == False">
                                            <span class="badge bg-secondary opacity-50">
                                                <i class="fa fa-archive" title="Archivado" />
                                                Archivado
                                            </span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>