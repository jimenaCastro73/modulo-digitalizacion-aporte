<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         proyecto_views.xml — Vistas backend: digitalizacion.proyecto
         Modelo T-03 · Registro central de proyectos de digitalizacion
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)

         Cambios respecto a versión anterior:
           - Eliminado tab "Líderes asignados": el líder se gestiona
             directamente desde "Miembros del equipo" marcando es_lider.
           - es_lider ahora es editable (no readonly) en la tabla de miembros.
         ================================================================ -->
    <!-- ================================================================
         1. VISTA LISTA
         ================================================================ -->
    <record id="digitalizacion_proyecto_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.list</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <tree string="Proyectos" default_order="fecha_inicio desc" decoration-success="state == 'activo'" decoration-muted="not active" decoration-warning="state == 'inactivo'">
                <field name="name" string="Proyecto" />
                <field name="fecha_inicio" string="Inicio" />
                <field name="fecha_fin_estimada" string="Fin estimado" optional="show" />
                <field name="state" string="Estado" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'inactivo'" />
                <field name="total_miembros" string="Miembros" optional="show" />
                <field name="total_registros" string="Registros" optional="show" />
                <field name="total_escaneos" string="Escaneos" optional="show" />
                <field name="progreso" string="Progreso %" widget="progressbar" optional="show" />
                <field name="active" column_invisible="1" />
            </tree>
        </field>
    </record>
    <!-- ================================================================
         2. VISTA KANBAN
         ================================================================ -->
    <record id="digitalizacion_proyecto_view_kanban" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.kanban</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="name" />
                <field name="state" />
                <field name="fecha_inicio" />
                <field name="fecha_fin_estimada" />
                <field name="progreso" />
                <field name="total_miembros" />
                <field name="total_escaneos" />
                <field name="meta_escaneos" />
                <field name="active" />
                <field name="color" />
                <field name="lider_ids" />
                <templates>
                    <t t-name="menu">
                        <a t-if="widget.editable" type="edit" role="menuitem" class="dropdown-item">Editar</a>
                        <a t-if="widget.deletable" type="delete" role="menuitem" class="dropdown-item">Eliminar</a>
                        <ul class="oe_kanban_colorpicker" data-field="color" />
                    </t>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_{{kanban_getcolor(record.color.raw_value)}} oe_kanban_global_click">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong class="o_kanban_record_title fs-5">
                                    <field name="name" />
                                </strong>
                                <field name="state" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'inactivo'" />
                            </div>
                            <div class="text-muted small mb-2">
                                <i class="fa fa-calendar-o me-1" />
                                Inicio:
                                <field name="fecha_inicio" />
                                <t t-if="record.fecha_fin_estimada.raw_value">
                                    ·  Fin est.:
                                    <field name="fecha_fin_estimada" />
                                </t>
                            </div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Progreso</span>
                                    <span>
                                        <field name="total_escaneos" />
                                        <t t-if="record.meta_escaneos.raw_value">
                                            /
                                            <field name="meta_escaneos" />
                                            esc.
                                        </t>
                                    </span>
                                </div>
                                <field name="progreso" widget="progressbar" options="{'editable': false}" />
                            </div>
                            <div class="d-flex justify-content-between align-items-end mt-2 pt-2" style="border-top: 1px solid #e0ddd6;">
                                <div class="d-flex gap-3">
                                    <div class="text-center">
                                        <div class="fw-bold">
                                            <field name="total_miembros" />
                                        </div>
                                        <div class="text-muted" style="font-size:10px;">Miembros</div>
                                    </div>
                                    <div class="text-center">
                                        <div class="fw-bold">
                                            <field name="total_escaneos" />
                                        </div>
                                        <div class="text-muted" style="font-size:10px;">Escaneos</div>
                                    </div>
                                </div>
                                <field name="lider_ids" widget="many2many_avatar_user" readonly="1" />
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- ================================================================
         3. VISTA FORMULARIO
         ================================================================ -->
    <record id="digitalizacion_proyecto_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.form</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <form string="Proyecto de Digitalizacion">
                <field name="active" invisible="1" />
                <header>
                    <button name="action_inactivar" string="Marcar Inactivo" type="object" class="btn-secondary" invisible="state != 'activo' or not active" confirm="El proyecto pasara a estado Inactivo. Los lideres seguiran viendo el proyecto pero no podran crear nuevos registros. Continuar?" />
                    <button name="action_activar" string="Reactivar" type="object" class="btn-primary" invisible="state == 'activo' and active" />
                    <button name="action_archivar" string="Archivar Proyecto" type="object" class="btn-secondary" invisible="not active" confirm="Se archivara el proyecto y se desactivaran todas sus asignaciones de lider. Esta accion es reversible. Continuar?" />
                    <field name="state" widget="statusbar" statusbar_visible="activo,inactivo" />
                </header>
                <!-- Stat buttons -->
                <div name="button_box" class="oe_button_box">
                    <button name="action_ver_registros" type="object" class="oe_stat_button" icon="fa-list-ul">
                        <field name="total_registros" string="Registros" widget="statinfo" />
                    </button>
                    <button name="action_ver_miembros" type="object" class="oe_stat_button" icon="fa-users">
                        <field name="total_miembros" string="Miembros" widget="statinfo" />
                    </button>
                    <button name="action_ver_registros" type="object" class="oe_stat_button" icon="fa-barcode" invisible="total_escaneos == 0">
                        <field name="total_escaneos" string="Escaneos" widget="statinfo" />
                    </button>
                </div>
                <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active" />
                <div class="alert alert-info" role="alert" invisible="state != 'inactivo' or not active">
                    <i class="fa fa-pause-circle me-1" />
                    Proyecto en estado
                    <strong>Inactivo</strong>
                    .
                    Los lideres asignados no pueden crear nuevos registros.
                </div>
                <sheet>
                    <div class="oe_title">
                        <label string="Nombre del proyecto" for="name" />
                        <h1>
                            <field name="name" placeholder="Ej: Imprema 2026, Centro Civico Expedientes..." required="1" />
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del proyecto">
                            <field name="fecha_inicio" string="Fecha de inicio" required="1" />
                            <field name="fecha_fin_estimada" string="Fecha fin estimada" />
                            <field name="duracion_estimada" string="Duracion estimada" readonly="1" invisible="duracion_estimada == 0" />
                        </group>
                        <group string="Meta y progreso">
                            <field name="meta_escaneos" string="Meta de escaneos" />
                            <field name="progreso" string="Progreso (%)" widget="progressbar" readonly="1" invisible="meta_escaneos == 0" />
                            <field name="lider_ids" string="Lideres activos" readonly="1" widget="many2many_tags" invisible="not lider_ids" />
                        </group>
                    </group>
                    <group string="Descripcion">
                        <field name="description" string="Descripcion" placeholder="Alcance del proyecto, cliente, ubicacion fisica de los documentos..." nolabel="1" />
                    </group>
                    <!-- ── Pestaña única: Miembros del equipo ───────────── -->
                    <notebook>
                        <page name="page_miembros" string="Miembros del equipo">
                            <!-- Nota informativa sobre cómo asignar líder -->
                            <div class="alert alert-info" role="alert">
                                <i class="fa fa-info-circle me-1" />
                                Para asignar un
                                <strong>líder</strong>
                                , agrega el miembro y activa
                                el toggle
                                <strong>Es líder</strong>
                                en su fila. El miembro debe
                                tener un usuario portal de Odoo creado previamente. Solo puede
                                haber un líder activo por proyecto.
                            </div>
                            <field name="miembro_ids" context="{'default_proyecto_id': active_id}">
                                <tree editable="bottom" decoration-muted="not active" decoration-info="es_lider">
                                    <field name="partner_id" string="Contacto / Digitalizador" required="1" />
                                    <field name="fecha_integracion" string="Ingreso" />
                                    <field name="fecha_salida" string="Salida" optional="show" />
                                    <field name="es_lider" string="Es lider" widget="boolean_toggle" />
                                    <field name="total_registros" string="Registros" optional="show" readonly="1" />
                                    <field name="active" string="Activo" widget="boolean_toggle" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- ================================================================
         4. VISTA BÚSQUEDA
         ================================================================ -->
    <record id="digitalizacion_proyecto_view_search" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.search</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <search string="Buscar proyectos">
                <field name="name" string="Nombre del proyecto" filter_domain="[('name', 'ilike', self)]" />
                <field name="description" string="Descripcion" filter_domain="[('description', 'ilike', self)]" />
                <filter name="filter_activos" string="Activos" domain="[('state', '=', 'activo'), ('active', '=', True)]" />
                <filter name="filter_mis_proyectos" string="Mis Proyectos" domain="[('asignacion_ids.lider_id', 'in', [uid])]" />
                <separator />
                <filter name="filter_inactivos" string="Inactivos" domain="[('state', '=', 'inactivo')]" />
                <filter name="filter_archivados" string="Archivados" domain="[('active', '=', False)]" />
                <separator />
                <filter name="filter_sin_meta" string="Sin meta definida" domain="[('meta_escaneos', '=', 0)]" />
                <filter name="filter_Este_Anio" string="Iniciados este anio" domain="[('fecha_inicio', '&gt;=', (context_today() + relativedelta(month=1, day=1)).strftime('%Y-%m-%d'))]" />
                <group string="Agrupar por" expand="0">
                    <filter name="group_estado" string="Estado" context="{'group_by': 'state'}" />
                    <filter name="group_fecha_inicio" string="Mes de inicio" context="{'group_by': 'fecha_inicio:month'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- ================================================================
         5. ACCIÓN PRINCIPAL
         ================================================================ -->
    <record id="digitalizacion_proyecto_action" model="ir.actions.act_window">
        <field name="name">Proyectos</field>
        <field name="res_model">digitalizacion.proyecto</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="digitalizacion_proyecto_view_tree" />
        <field name="search_view_id" ref="digitalizacion_proyecto_view_search" />
        <field name="context">{"search_default_filter_activos": 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea el primer proyecto de digitalizacion</p>
            <p>Cada proyecto representa un contrato o encargo de digitalizacion.</p>
        </field>
    </record>
</odoo>