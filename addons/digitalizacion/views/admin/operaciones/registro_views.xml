<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         registro_views.xml — Vistas del backend para digitalizacion.registro
         Modelo T-06 · Registro diario de trabajo de digitalización

         Campos visibles según etapa (expresiones Python directas, sin attrs):
           Limpieza / Ordenado → referencia_cajas, no_expedientes, total_folios
           Digitalizado        → referencia_cajas, no_expedientes, total_folios,
                                 total_escaneos, tipo_escaner_ids
           Editado             → expedientes_editados, folios_editados
           Indexado            → expedientes_indexados, folios_indexados
         ================================================================ -->
    <!-- 1. VISTA LISTA -->
    <record id="digitalizacion_registro_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.registro.list</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <tree string="Registros de Trabajo" default_order="fecha desc, id desc" decoration-muted="not fecha">
                <field name="fecha" string="Fecha" />
                <field name="miembro_nombre" string="Digitalizador" />
                <field name="proyecto_nombre" string="Proyecto" optional="show" />
                <field name="etapa_nombre" string="Etapa" />
                <field name="referencia_cajas" string="Ref. cajas" optional="show" />
                <field name="produccion_principal" string="Producción" />
                <field name="unidad_produccion" string="Unidad" />
                <field name="total_folios" string="Folios" optional="hide" />
                <field name="total_escaneos" string="Escaneos" optional="hide" />
                <field name="lider_nombre" string="Registrado por" optional="hide" />
                <field name="hora" string="Hora envío" optional="hide" />
                <!-- Campos invisibles necesarios para expresiones -->
                <field name="etapa_id" column_invisible="True" />
                <field name="miembro_id" column_invisible="True" />
                <field name="proyecto_id" column_invisible="True" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA FORMULARIO -->
    <record id="digitalizacion_registro_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.registro.form</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <form string="Registro de Trabajo">
                <header>
                    <button name="action_duplicar_para_hoy" string="Duplicar para hoy" type="object" class="btn-secondary" />
                </header>
                <sheet>
                    <!-- ── Identificación del registro ── -->
                    <group>
                        <group string="Registro">
                            <field name="fecha" required="1" />
                            <field name="hora" readonly="1" />
                            <field name="lider_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                        </group>
                        <group string="Asignación">
                            <field name="proyecto_id" required="1" options="{'no_create': True}" />
                            <field name="miembro_id" required="1" options="{'no_create': True}" domain="[('proyecto_id', '=', proyecto_id), ('active', '=', True), ('fecha_salida', '=', False)]" />
                            <field name="etapa_id" required="1" options="{'no_create': True}" />
                        </group>
                    </group>
                    <!-- ── Campos Limpieza / Ordenado ── -->
                    <group string="Datos de producción — Limpieza / Ordenado" invisible="etapa_nombre not in ['Limpieza', 'Ordenado']">
                        <group>
                            <field name="referencia_cajas" string="Referencia de cajas" placeholder="Ej: BF202, BF199, BF208 o '7 cajas'" invisible="etapa_nombre not in ['Limpieza', 'Ordenado']" />
                            <field name="no_expedientes" string="Cantidad de expedientes" invisible="etapa_nombre not in ['Limpieza', 'Ordenado']" />
                        </group>
                        <group>
                            <field name="total_folios" string="Cantidad de folios" invisible="etapa_nombre not in ['Limpieza', 'Ordenado']" />
                        </group>
                    </group>
                    <!-- ── Campos Digitalizado ── -->
                    <group string="Datos de producción — Digitalizado" invisible="etapa_nombre != 'Digitalizado'">
                        <group>
                            <field name="referencia_cajas" string="Referencia de cajas" placeholder="Ej: BF202, BF199, BF208 o '5 cajas'" invisible="etapa_nombre != 'Digitalizado'" />
                            <field name="no_expedientes" string="Cantidad de expedientes" invisible="etapa_nombre != 'Digitalizado'" />
                        </group>
                        <group>
                            <field name="total_folios" string="Cantidad de folios (físicos)" invisible="etapa_nombre != 'Digitalizado'" />
                            <field name="total_escaneos" string="Número de escaneos (hojas digitales)" invisible="etapa_nombre != 'Digitalizado'" />
                            <field name="tipo_escaner_ids" string="Tipo(s) de escáner" widget="many2many_tags" invisible="etapa_nombre != 'Digitalizado'" />
                        </group>
                    </group>
                    <!-- ── Campos Editado ── -->
                    <group string="Datos de producción — Editado" invisible="etapa_nombre != 'Editado'">
                        <group>
                            <field name="expedientes_editados" string="Expedientes editados" invisible="etapa_nombre != 'Editado'" />
                        </group>
                        <group>
                            <field name="folios_editados" string="Folios editados" invisible="etapa_nombre != 'Editado'" />
                        </group>
                    </group>
                    <!-- ── Campos Indexado ── -->
                    <group string="Datos de producción — Indexado" invisible="etapa_nombre != 'Indexado'">
                        <group>
                            <field name="expedientes_indexados" string="Expedientes indexados" invisible="etapa_nombre != 'Indexado'" />
                        </group>
                        <group>
                            <field name="folios_indexados" string="Folios indexados" invisible="etapa_nombre != 'Indexado'" />
                        </group>
                    </group>
                    <!-- Campos invisibles para usar en expresiones -->
                    <field name="etapa_nombre" invisible="1" />
                    <field name="proyecto_nombre" invisible="1" />
                    <field name="miembro_nombre" invisible="1" />
                    <!-- ── Producción resumida (readonly) ── -->
                    <group string="Resumen" invisible="not produccion_principal">
                        <group>
                            <field name="produccion_principal" string="Producción del día" readonly="1" />
                            <field name="unidad_produccion" string="Unidad" readonly="1" />
                        </group>
                    </group>
                    <!-- ── Observaciones ── -->
                    <group>
                        <field name="observacion" string="Observaciones" placeholder="Incidencias, notas de la jornada..." />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 3. VISTA PIVOT -->
    <record id="digitalizacion_registro_view_pivot" model="ir.ui.view">
        <field name="name">digitalizacion.registro.pivot</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Producción" disable_linking="0">
                <field name="proyecto_nombre" type="row" />
                <field name="miembro_nombre" type="row" />
                <field name="etapa_nombre" type="col" />
                <field name="produccion_principal" string="Producción" type="measure" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
                <field name="total_folios" string="Folios" type="measure" />
                <field name="expedientes_indexados" string="Exp. indexados" type="measure" />
                <field name="fecha" type="col" interval="month" invisible="1" />
            </pivot>
        </field>
    </record>
    <!-- 4. VISTA GRÁFICO -->
    <record id="digitalizacion_registro_view_graph" model="ir.ui.view">
        <field name="name">digitalizacion.registro.graph</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <graph string="Producción por Digitalizador" type="bar" stacked="1">
                <field name="miembro_nombre" string="Digitalizador" type="row" />
                <field name="etapa_nombre" string="Etapa" type="col" />
                <field name="produccion_principal" string="Producción" type="measure" />
            </graph>
        </field>
    </record>
    <!-- 5. VISTA BÚSQUEDA -->
    <record id="digitalizacion_registro_view_search" model="ir.ui.view">
        <field name="name">digitalizacion.registro.search</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <search string="Buscar registros">
                <field name="miembro_nombre" string="Digitalizador" filter_domain="[('miembro_nombre', 'ilike', self)]" />
                <field name="proyecto_nombre" string="Proyecto" filter_domain="[('proyecto_nombre', 'ilike', self)]" />
                <field name="etapa_nombre" string="Etapa" filter_domain="[('etapa_nombre', 'ilike', self)]" />
                <field name="referencia_cajas" string="Ref. cajas" filter_domain="[('referencia_cajas', 'ilike', self)]" />
                <separator />
                <filter name="hoy" string="Hoy" domain="[('fecha', '=', context_today().strftime('%Y-%m-%d'))]" />
                <filter name="semana" string="Esta semana" domain="[('fecha', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]" />
                <filter name="mes" string="Este mes" domain="[('fecha', '>=', context_today().strftime('%Y-%m-01'))]" />
                <separator />
                <filter name="limpieza" string="Limpieza" domain="[('etapa_nombre', '=', 'Limpieza')]" />
                <filter name="ordenado" string="Ordenado" domain="[('etapa_nombre', '=', 'Ordenado')]" />
                <filter name="digitalizado" string="Digitalizado" domain="[('etapa_nombre', '=', 'Digitalizado')]" />
                <filter name="editado" string="Editado" domain="[('etapa_nombre', '=', 'Editado')]" />
                <filter name="indexado" string="Indexado" domain="[('etapa_nombre', '=', 'Indexado')]" />
                <group string="Agrupar por" expand="1">
                    <filter name="group_proyecto" string="Proyecto" context="{'group_by': 'proyecto_nombre'}" />
                    <filter name="group_miembro" string="Digitalizador" context="{'group_by': 'miembro_nombre'}" />
                    <filter name="group_etapa" string="Etapa" context="{'group_by': 'etapa_nombre'}" />
                    <filter name="group_fecha" string="Fecha" context="{'group_by': 'fecha:day'}" />
                    <filter name="group_mes" string="Mes" context="{'group_by': 'fecha:month'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- 6. ACCIÓN -->
    <record id="digitalizacion_registro_action" model="ir.actions.act_window">
        <field name="name">Registros de Trabajo</field>
        <field name="res_model">digitalizacion.registro</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="digitalizacion_registro_view_search" />
        <field name="context">{'search_default_mes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aún no hay registros de trabajo</p>
            <p>Los registros son creados por el Líder desde el portal web
                al final de cada jornada de digitalización.</p>
        </field>
    </record>
</odoo>