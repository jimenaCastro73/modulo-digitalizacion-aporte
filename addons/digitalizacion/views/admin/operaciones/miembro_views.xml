<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         miembro_views.xml — Vistas del backend para digitalizacion.miembro_proyecto
         Modelo T-05 · Integrantes del equipo de digitalización por proyecto
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)
         ================================================================ -->
    <!-- 1. VISTA LISTA -->
    <record id="digitalizacion_miembro_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.miembro_proyecto.list</field>
        <field name="model">digitalizacion.miembro_proyecto</field>
        <field name="arch" type="xml">
            <tree string="Miembros del Equipo" default_order="proyecto_id asc, partner_name asc" decoration-muted="not active or fecha_salida" decoration-success="es_lider">
                <field name="partner_id" string="Digitalizador" />
                <field name="proyecto_id" string="Proyecto" />
                <field name="fecha_integracion" string="Integración" />
                <field name="fecha_salida" string="Salida" optional="show" />
                <field name="es_lider" string="Líder" widget="boolean_toggle" />
                <field name="total_registros" string="Registros" optional="show" />
                <field name="active" column_invisible="True" />
                <button name="action_registrar_salida" string="Registrar salida" type="object" icon="fa-sign-out" invisible="fecha_salida or not active" title="Registrar fecha de salida del miembro" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA FORMULARIO -->
    <record id="digitalizacion_miembro_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.miembro_proyecto.form</field>
        <field name="model">digitalizacion.miembro_proyecto</field>
        <field name="arch" type="xml">
            <form string="Miembro del Equipo">
                <header>
                    <button name="action_registrar_salida" string="Registrar salida" type="object" class="btn-secondary" invisible="fecha_salida or not active" />
                    <button name="action_reintegrar" string="Reintegrar" type="object" class="btn-primary" invisible="not fecha_salida" />
                </header>
                <div name="button_box" class="oe_button_box">
                    <button name="action_ver_registros" type="object" class="oe_stat_button" icon="fa-list-ul" invisible="total_registros == 0">
                        <field name="total_registros" string="Registros" widget="statinfo" />
                    </button>
                </div>
                <field name="active" widget="boolean_toggle" invisible="1" />
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not fecha_salida">
                        <i class="fa fa-exclamation-triangle me-1" />
                        Este miembro tiene fecha de salida registrada
                        y no aparece en el formulario de registro del portal.
                    </div>
                    <div class="alert alert-info" role="alert" invisible="not es_lider">
                        <i class="fa fa-star me-1" />
                        Este miembro es el Líder del proyecto. Tiene acceso
                        al portal web y registra la producción del equipo.
                    </div>
                    <group>
                        <group string="Datos del miembro">
                            <field name="partner_id" string="Contacto" options="{'no_create': False}" required="1" />
                            <field name="proyecto_id" string="Proyecto" options="{'no_create': True}" required="1" />
                            <field name="es_lider" string="Es líder del proyecto" widget="boolean_toggle" />
                        </group>
                        <group string="Fechas">
                            <field name="fecha_integracion" string="Fecha de integración" />
                            <field name="fecha_salida" string="Fecha de salida" />
                            <field name="active" string="Activo" widget="boolean_toggle" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 3. VISTA BÚSQUEDA -->
    <record id="digitalizacion_miembro_view_search" model="ir.ui.view">
        <field name="name">digitalizacion.miembro_proyecto.search</field>
        <field name="model">digitalizacion.miembro_proyecto</field>
        <field name="arch" type="xml">
            <search string="Buscar miembros">
                <field name="partner_id" string="Digitalizador" />
                <field name="proyecto_id" string="Proyecto" />
                <separator />
                <filter name="activos" string="Activos" domain="[('active', '=', True), ('fecha_salida', '=', False)]" />
                <filter name="con_salida" string="Con salida registrada" domain="[('fecha_salida', '!=', False)]" />
                <filter name="lideres" string="Líderes" domain="[('es_lider', '=', True)]" />
                <group string="Agrupar por" expand="0">
                    <filter name="group_proyecto" string="Proyecto" context="{'group_by': 'proyecto_id'}" />
                    <filter name="group_mes" string="Mes de integración" context="{'group_by': 'fecha_integracion:month'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- 4. ACCIÓN -->
    <record id="digitalizacion_miembro_action" model="ir.actions.act_window">
        <field name="name">Miembros del Equipo</field>
        <field name="res_model">digitalizacion.miembro_proyecto</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="digitalizacion_miembro_view_search" />
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Agrega el primer miembro al equipo</p>
            <p>Los miembros son los digitalizadores cuya producción
                diaria registra el Líder desde el portal.</p>
        </field>
    </record>
</odoo>