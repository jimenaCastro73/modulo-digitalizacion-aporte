<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         dashboard_views.xml — Dashboard de producción para el Administrador
         Vistas de análisis global: gráfico de barras por digitalizador,
         tendencia diaria de escaneos, y pivot cruzado.
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)
         ================================================================ -->
    <!-- 1. GRAPH — Producción por digitalizador (barras) -->
    <record id="digitalizacion_dashboard_graph_miembro" model="ir.ui.view">
        <field name="name">digitalizacion.registro.graph.miembro</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <graph string="Producción por Digitalizador" type="bar" stacked="0">
                <field name="miembro_nombre" string="Digitalizador" type="row" />
                <field name="produccion_principal" string="Producción" type="measure" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
            </graph>
        </field>
    </record>
    <!-- 2. GRAPH — Tendencia diaria de escaneos (línea) -->
    <record id="digitalizacion_dashboard_graph_tendencia" model="ir.ui.view">
        <field name="name">digitalizacion.registro.graph.tendencia</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <graph string="Tendencia Diaria de Escaneos" type="line">
                <field name="fecha" string="Fecha" type="row" interval="day" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
            </graph>
        </field>
    </record>
    <!-- 3. PIVOT — Análisis cruzado -->
    <record id="digitalizacion_dashboard_pivot" model="ir.ui.view">
        <field name="name">digitalizacion.registro.pivot.dashboard</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <pivot string="Análisis Cruzado de Producción" display_quantity="1" default_order="miembro_nombre asc">
                <field name="proyecto_nombre" string="Proyecto" type="row" />
                <field name="miembro_nombre" string="Digitalizador" type="row" />
                <field name="etapa_nombre" string="Etapa" type="col" />
                <field name="produccion_principal" string="Producción" type="measure" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
                <field name="total_folios" string="Folios físicos" type="measure" />
                <field name="expedientes_indexados" string="Exp. indexados" type="measure" />
                <field name="fecha" type="col" interval="month" invisible="1" />
            </pivot>
        </field>
    </record>
    <!-- 4. ACCIÓN DASHBOARD — combina las tres vistas -->
    <record id="digitalizacion_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard de Producción</field>
        <field name="res_model">digitalizacion.registro</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="view_id" ref="digitalizacion_dashboard_graph_miembro" />
        <field name="context">{
            'search_default_mes': 1,
            'graph_measure': 'produccion_principal',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aún no hay datos de producción</p>
            <p>El dashboard mostrará la producción del equipo
                una vez que el Líder comience a registrar jornadas.</p>
        </field>
    </record>
</odoo>
