<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
    dashboard_admin.xml - Dashboard Admin (Dashboard 1)
         Referencia tecnica: DASHBOARD_SPEC.md (Secciones A, B, C, D, E)
         Acceso: grupo Digitalizacion / Administrador
         Modelo base: digitalizacion.registro + digitalizacion.proyecto

         Estrategia de implementacion en Odoo Community:
           - Seccion A (KPIs): vista form con stat buttons sobre
             digitalizacion.proyecto (suma acumulada de todos los proyectos)
           - Seccion B (Progreso): vista list de proyectos con progressbar
           - Seccion C (por digitalizador): graph type="bar"
           - Seccion D (tendencia diaria): graph type="line"
           - Seccion E (filtros): search view con filtros de mes y agrupaciones
         ================================================================ -->
    <!-- ================================================================
         SECCION A + B - Vista form KPIs globales + progreso por proyecto
         Modelo: digitalizacion.proyecto
         Muestra los totales acumulados del mes y el progreso de cada
         proyecto activo. Usamos una vista list de proyectos con
         columnas de KPI y barra de progreso como aproximacion a la
         Seccion A del spec (Odoo Community no tiene dashboard builder).
         ================================================================ -->
    <!-- Section A+B moved/redundant - commenting out to fix validation error
    <record id="view_dashboard_proyecto_list" model="ir.ui.view">
        <field name="name">digitalizacion.proyecto.dashboard</field>
        <field name="model">digitalizacion.proyecto</field>
        <field name="arch" type="xml">
            <tree string="Resumen de Proyectos" default_order="state asc, fecha_inicio desc" decoration-muted="state == 'inactivo'" create="0" delete="0" editable="0">
                <field name="name" string="Proyecto" />
                <field name="state" string="Estado" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'inactivo'" />
                <field name="total_miembros" string="Miembros" sum="Total miembros" />
                <field name="total_escaneos" string="Escaneos acumulados" />
                <field name="meta_escaneos" string="Meta" />
                <field name="progreso" string="Progreso %" widget="progressbar" options="{'max_value': 100}" />
                <field name="fecha_fin_estimada" string="Fin estimado" optional="show" />
                <field name="total_registros" string="Registros" optional="show" />
            </tree>
        </field>
    </record>
    -->
    <!-- 
    <record id="action_dashboard_proyectos" model="ir.actions.act_window">
        <field name="name">Resumen de Proyectos</field>
        <field name="res_model">digitalizacion.proyecto</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_dashboard_proyecto_list"/>
        <field name="domain">[('active', '=', True)]</field>
        <field name="context">{"search_default_filter_activos": 1}</field>
    </record>
    -->
    <!-- ================================================================
         SECCION C — Produccion por digitalizador (grafico de barras)
         Referencia: DASHBOARD_SPEC.md Seccion C
         Agrupa por miembro_id, mide total_escaneos / total_folios /
         expedientes_indexados. Filtrado por mes actual por defecto.
         ================================================================ -->
    <record id="view_registro_graph_por_digitalizador" model="ir.ui.view">
        <field name="name">digitalizacion.registro.graph.digitalizador</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <graph string="Produccion por Digitalizador" type="bar" stacked="0">
                <field name="miembro_id" type="row" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
                <field name="total_folios" string="Folios fisicos" type="measure" />
                <field name="expedientes_indexados" string="Exp. indexados" type="measure" />
                <field name="folios_indexados" string="Folios indexados" type="measure" />
            </graph>
        </field>
    </record>
    <!-- ================================================================
         SECCION D — Tendencia diaria de escaneos (grafico de linea)
         Referencia: DASHBOARD_SPEC.md Seccion D
         Eje X = fecha, Eje Y = total_escaneos del dia (todos los
         digitalizadores). Separado por proyecto como segunda dimension.
         ================================================================ -->
    <record id="view_registro_graph_tendencia" model="ir.ui.view">
        <field name="name">digitalizacion.registro.graph.tendencia</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <graph string="Tendencia Diaria de Escaneos" type="line">
                <field name="fecha" type="row" interval="day" />
                <field name="proyecto_id" type="col" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
            </graph>
        </field>
    </record>
    <!-- ================================================================
         SECCION C — Pivot: analisis cruzado para el Admin
         Complementa la grafica de barras con datos tabulares precisos.
         ================================================================ -->
    <record id="view_registro_pivot_dashboard" model="ir.ui.view">
        <field name="name">digitalizacion.registro.pivot.dashboard</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <pivot string="Produccion por Digitalizador" disable_linking="false">
                <field name="proyecto_id" type="row" />
                <field name="miembro_id" type="row" />
                <field name="etapa_id" type="col" />
                <field name="total_escaneos" string="Escaneos" type="measure" />
                <field name="total_folios" string="Folios fisicos" type="measure" />
                <field name="expedientes_indexados" string="Exp. indexados" type="measure" />
                <field name="folios_indexados" string="Folios indexados" type="measure" />
            </pivot>
        </field>
    </record>
    <!-- ================================================================
         SECCION E — Filtros del dashboard
         Referencia: DASHBOARD_SPEC.md Seccion E
         Filtros por periodo + agrupaciones por proyecto / digitalizador /
         fecha. Separado del search de operaciones para no contaminar
         la vista de registros del admin con defaults del dashboard.
         ================================================================ -->
    <record id="view_registro_search_dashboard" model="ir.ui.view">
        <field name="name">digitalizacion.registro.search.dashboard</field>
        <field name="model">digitalizacion.registro</field>
        <field name="arch" type="xml">
            <search string="Filtros Dashboard">
                <!-- Busqueda rapida por proyecto o digitalizador -->
                <field name="proyecto_id" string="Proyecto" filter_domain="[('proyecto_id.name', 'ilike', self)]" />
                <field name="miembro_id" string="Digitalizador" filter_domain="[('miembro_id.partner_id.name', 'ilike', self)]" />
                <!-- Filtros de periodo -->
                <filter name="este_mes" string="Este mes" domain="[('fecha', '>=', context_today().strftime('%Y-%m-01')), ('fecha', '<=', context_today().strftime('%Y-%m-%d'))]" />
                <filter name="mes_anterior" string="Mes anterior" domain="[('fecha', '>=', (context_today() + relativedelta(months=-1, day=1)).strftime('%Y-%m-%d')), ('fecha', '<=', (context_today() + relativedelta(day=1, days=-1)).strftime('%Y-%m-%d'))]" />
                <filter name="este_anio" string="Este año" domain="[('fecha', '>=', context_today().strftime('%Y-01-01')), ('fecha', '<=', context_today().strftime('%Y-%m-%d'))]" />
                <separator />
                <!-- Agrupaciones -->
                <group string="Agrupar por" expand="1">
                    <filter name="por_proyecto" string="Proyecto" context="{'group_by': 'proyecto_id'}" />
                    <filter name="por_digitalizador" string="Digitalizador" context="{'group_by': 'miembro_id'}" />
                    <filter name="por_etapa" string="Etapa" context="{'group_by': 'etapa_id'}" />
                    <filter name="por_fecha_dia" string="Dia" context="{'group_by': 'fecha:day'}" />
                    <filter name="por_fecha_mes" string="Mes" context="{'group_by': 'fecha:month'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- ================================================================
         ACCION DEL DASHBOARD — registros con vistas especificas
         view_ids: orden graph(digitalizador) → graph(tendencia) → pivot → list
         Filtro por defecto: mes actual agrupado por proyecto.
         ================================================================ -->
    <record id="action_digitalizacion_dashboard_admin" model="ir.actions.act_window">
        <field name="name">Dashboard de Produccion</field>
        <field name="res_model">digitalizacion.registro</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_registro_search_dashboard" />
        <field name="view_ids" eval="[(5, 0, 0),                       (0, 0, {'view_mode': 'graph', 'view_id': ref('view_registro_graph_por_digitalizador')}),                       (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_registro_pivot_dashboard')})]" />
        <field name="context">{
            'search_default_este_mes': 1,
            'search_default_por_proyecto': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aun no hay registros de produccion.</p>
            <p>Los lideres del portal alimentaran este dashboard diariamente.</p>
        </field>
    </record>
    <!-- ================================================================
         MENU ITEM DEL DASHBOARD
         parent: menu_digitalizacion_operaciones (ID correcto en menus.xml)
         sequence=1: aparece primero en el menu de Operaciones
         groups: restringido al Admin
         ================================================================ -->
    <!-- ================================================================
         MENU ITEM DEL DASHBOARD
         parent: menu_digitalizacion_operaciones (ID correcto en menus.xml)
         sequence=1: aparece primero en el menu de Operaciones
         groups: restringido al Admin
         ================================================================ -->
    <menuitem id="menu_dashboard_admin" name="Dashboard" parent="digitalizacion.menu_digitalizacion_operaciones" action="action_digitalizacion_dashboard_admin" sequence="1" groups="digitalizacion.group_digitalizacion_admin" />
</odoo>