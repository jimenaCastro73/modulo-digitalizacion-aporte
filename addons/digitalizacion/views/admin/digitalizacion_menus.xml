<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         digitalizacion_menus.xml — Árbol de menús del módulo
         Fuente única de verdad para la navegación del backoffice.

         Estructura:
           Digitalización
           ├── Dashboard
           ├── Proyectos
           │   ├── Proyectos
           │   └── Asignar Líderes
           ├── Operaciones
           │   ├── Miembros del Equipo
           │   └── Registros de Trabajo
           └── Configuración
               ├── Etapas
               └── Tipos de Escáner

         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin).
         Los menús se cargan DESPUÉS de todas las vistas y acciones.
         ================================================================ -->
    <!-- RAÍZ -->
    <menuitem id="menu_digitalizacion_root" name="Digitalización" sequence="50" groups="digitalizacion.group_digitalizacion_admin" web_icon="digitalizacion,static/description/icon.png" />
    <!-- DASHBOARD -->
    <menuitem id="menu_digitalizacion_dashboard" name="Dashboard" parent="menu_digitalizacion_root" action="digitalizacion_dashboard_action" sequence="10" groups="digitalizacion.group_digitalizacion_admin" />
    <!-- PROYECTOS -->
    <menuitem id="menu_digitalizacion_proyectos" name="Proyectos" parent="menu_digitalizacion_root" sequence="20" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_proyectos_lista" name="Proyectos" parent="menu_digitalizacion_proyectos" action="digitalizacion_proyecto_action" sequence="10" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_asignacion" name="Asignar Líderes" parent="menu_digitalizacion_proyectos" action="digitalizacion_asignacion_action" sequence="20" groups="digitalizacion.group_digitalizacion_admin" />
    <!-- OPERACIONES -->
    <menuitem id="menu_digitalizacion_operaciones" name="Operaciones" parent="menu_digitalizacion_root" sequence="30" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_miembros" name="Miembros del Equipo" parent="menu_digitalizacion_operaciones" action="digitalizacion_miembro_action" sequence="10" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_registros" name="Registros de Trabajo" parent="menu_digitalizacion_operaciones" action="digitalizacion_registro_action" sequence="20" groups="digitalizacion.group_digitalizacion_admin" />
    <!-- CONFIGURACIÓN -->
    <menuitem id="menu_digitalizacion_configuracion" name="Configuración" parent="menu_digitalizacion_root" sequence="40" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_etapas" name="Etapas" parent="menu_digitalizacion_configuracion" action="digitalizacion_etapa_action" sequence="10" groups="digitalizacion.group_digitalizacion_admin" />

    <menuitem id="menu_digitalizacion_escaneres" name="Tipos de Escáner" parent="menu_digitalizacion_configuracion" action="digitalizacion_tipo_escaner_action" sequence="20" groups="digitalizacion.group_digitalizacion_admin" />
</odoo>