<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         tipo_escaner_views.xml — Vistas del backend para digitalizacion.tipo_escaner
         Modelo T-02 · Catálogo global de tipos de escáneres
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)
         ================================================================ -->
    <!-- 1. VISTA LISTA -->
    <record id="digitalizacion_tipo_escaner_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.tipo_escaner.list</field>
        <field name="model">digitalizacion.tipo_escaner</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Escáner" editable="bottom" decoration-muted="not active">
                <field name="name" string="Nombre / Modelo" />
                <field name="description" string="Descripción" optional="show" />
                <field name="active" string="Activo" widget="boolean_toggle" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA FORMULARIO -->
    <record id="digitalizacion_tipo_escaner_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.tipo_escaner.form</field>
        <field name="model">digitalizacion.tipo_escaner</field>
        <field name="arch" type="xml">
            <form string="Tipo de Escáner">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="active">
                        <i class="fa fa-archive me-1" />
                        Este escáner está archivado y no aparecerá en el formulario de registro del portal.
                    </div>
                    <div class="oe_title">
                        <label string="Nombre del escáner" for="name" />
                        <h1>
                            <field name="name" placeholder="Ej: Fujitsu fi-7300NX, Epson GT-S85..." required="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" string="Activo" widget="boolean_toggle" />
                        </group>
                    </group>
                    <field name="description" string="Descripción" placeholder="Velocidad, formato, ubicación física del equipo..." />
                </sheet>
            </form>
        </field>
    </record>
    <!-- 3. ACCIÓN -->
    <record id="digitalizacion_tipo_escaner_action" model="ir.actions.act_window">
        <field name="name">Tipos de Escáner</field>
        <field name="res_model">digitalizacion.tipo_escaner</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="digitalizacion_tipo_escaner_view_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra el primer tipo de escáner</p>
            <p>Los escáneres disponibles aparecerán en el formulario de registro del Líder al registrar producción en la etapa de Digitalizado.</p>
        </field>
    </record>
</odoo>