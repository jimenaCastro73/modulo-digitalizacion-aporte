<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         etapa_views.xml — Vistas del backend para digitalizacion.etapa
         Modelo T-01 - Catalogo de etapas del proceso de digitalizacion
         Acceso exclusivo: grupo Administrador (group_digitalizacion_admin)

         La accion de ventana y el item de menu se declaran en
         menus.xml (fuente unica de verdad para la navegacion).
         Este archivo solo define las vistas list y form.
         ================================================================ -->
    <!-- ================================================================
         1. VISTA LISTA
         editable="bottom": edicion directa en fila (ideal para catalogos).
         widget="handle" en sequence: drag-and-drop para reordenar.
         decoration-muted: atenua visualmente las etapas archivadas.
         ================================================================ -->
    <record id="digitalizacion_etapa_view_tree" model="ir.ui.view">
        <field name="name">digitalizacion.etapa.list</field>
        <field name="model">digitalizacion.etapa</field>
        <field name="arch" type="xml">
            <tree string="Etapas" default_order="sequence asc" editable="bottom" decoration-muted="not active">
                <field name="sequence" widget="handle" />
                <field name="name" string="Nombre de la etapa" />
                <field name="active" string="Activo" widget="boolean_toggle" />
            </tree>
        </field>
    </record>
    <!-- 2. VISTA FORMULARIO -->
    <record id="digitalizacion_etapa_view_form" model="ir.ui.view">
        <field name="name">digitalizacion.etapa.form</field>
        <field name="model">digitalizacion.etapa</field>
        <field name="arch" type="xml">
            <form string="Etapa de Digitalización">
                <header />
                <sheet>
                    <div class="oe_title">
                        <label string="Nombre de la etapa" for="name" />
                        <h1>
                            <field name="name" placeholder="Ej: Limpieza, Digitalizado, Editado..." required="1" />
                        </h1>
                    </div>
                    <group>
                        <group string="Configuración">
                            <field name="sequence" string="Secuencia" help="Orden de aparición en listas y selectores. Menor número = primera posición." />
                            <field name="active" string="Activo" widget="boolean_toggle" />
                        </group>
                    </group>
                    <!-- Alerta: etapa archivada -->
                    <div class="alert alert-warning" role="alert" invisible="active">
                        <i class="fa fa-archive" />
                        Esta etapa está archivada y no aparecerá en el formulario de registro del portal.
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 3. ACCIÓN PRINCIPAL DEL MODELO -->
    <record id="digitalizacion_etapa_action" model="ir.actions.act_window">
        <field name="name">Etapas</field>
        <field name="res_model">digitalizacion.etapa</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="digitalizacion_etapa_view_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea la primera etapa del proceso</p>
            <p>Define las fases del flujo: Limpieza, Digitalizado, Editado, Indexado, Ordenado.</p>
        </field>
    </record>
</odoo>